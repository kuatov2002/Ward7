  caseId: case_arson
  displayName: "\u041F\u043E\u0436\u0430\u0440 \u0432 \u0430\u0440\u0445\u0438\u0432\u0435"
  caseNumber: 3
  totalMoves: 9
  trueCulpritId: glumov
  persons:
  - personId: glumov
    displayName: "\u0413\u043B\u0443\u043C\u043E\u0432 \u0412.\u041F."
    role: 0
    hiddenAgenda: 2
    description: "\u0427\u0438\u043D\u043E\u0432\u043D\u0438\u043A \u0437\u0435\u043C\u0435\u043B\u044C\u043D\u043E\u0433\u043E
      \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430, 52 \u0433\u043E\u0434\u0430.
      \u0423\u0432\u0435\u0440\u0435\u043D\u043D\u043E \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F.
      \u0413\u043E\u0432\u043E\u0440\u0438\u0442 \u0447\u0442\u043E \u0443\u0437\u043D\u0430\u043B
      \u043E \u043F\u043E\u0436\u0430\u0440\u0435 \u0438\u0437 \u043D\u043E\u0432\u043E\u0441\u0442\u0435\u0439."
  - personId: fomina
    displayName: "\u041D\u0430\u0434\u0435\u0436\u0434\u0430 \u0424\u043E\u043C\u0438\u043D\u0430"
    role: 1
    hiddenAgenda: 0
    description: "\u0410\u0440\u0445\u0438\u0432\u0430\u0440\u0438\u0443\u0441, 61
      \u0433\u043E\u0434. \u0413\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u0430.
      \u0412\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u0437\u0430 \u0437\u0430\u0431\u044B\u0442\u044B\u043C\u0438
      \u043A\u043B\u044E\u0447\u0430\u043C\u0438 \u0438 \u0437\u0430\u0441\u0442\u0430\u043B\u0430
      \u043F\u043E\u0436\u0430\u0440."
  - personId: belov
    displayName: "\u0411\u0435\u043B\u043E\u0432 \u041A.\u0410."
    role: 0
    hiddenAgenda: 3
    description: "\u0417\u0430\u0441\u0442\u0440\u043E\u0439\u0449\u0438\u043A, 40
      \u043B\u0435\u0442. \u0415\u0433\u043E \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044F
      \u0432\u0435\u0434\u0451\u0442 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
      \u043D\u0430 \u0441\u043F\u043E\u0440\u043D\u044B\u0445 \u0443\u0447\u0430\u0441\u0442\u043A\u0430\u0445."
  - personId: rita
    displayName: "\u0420\u0438\u0442\u0430 \u0427\u0435\u0440\u043D\u043E\u0432\u0430"
    role: 1
    hiddenAgenda: 1
    description: "\u0421\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044C \u0437\u0435\u043C\u0435\u043B\u044C\u043D\u043E\u0433\u043E
      \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430. \u0420\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      \u043D\u0430 \u0413\u043B\u0443\u043C\u043E\u0432\u0430 7 \u043B\u0435\u0442."
  interrogations:
  - targetPersonId: glumov
    questions:
    - questionText: "\u0417\u0430\u0447\u0435\u043C \u043A\u043E\u043C\u0443-\u0442\u043E
        \u0436\u0435\u0447\u044C \u0430\u0440\u0445\u0438\u0432?"
      answerText: "\u041F\u043E\u043D\u044F\u0442\u0438\u044F \u043D\u0435 \u0438\u043C\u0435\u044E.
        \u041C\u043E\u0436\u0435\u0442 \u0431\u0435\u0437\u0434\u043E\u043C\u043D\u044B\u0435
        \u0433\u0440\u0435\u043B\u0438\u0441\u044C. \u0417\u0434\u0430\u043D\u0438\u0435
        \u0441\u0442\u0430\u0440\u043E\u0435, \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u043A\u0430
        \u0433\u043D\u0438\u043B\u0430\u044F."
      isLie: 1
      truthText: "\u0413\u043B\u0443\u043C\u043E\u0432 \u0437\u043D\u0430\u0435\u0442
        \u0447\u0442\u043E \u0432 \u0430\u0440\u0445\u0438\u0432\u0435 \u2014 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
        \u0435\u0433\u043E \u0430\u0444\u0435\u0440 \u0441 \u0437\u0435\u043C\u043B\u0451\u0439."
      revealedFragmentId: c3_frag_glumov_dismisses
    - questionText: "\u0412\u044B \u0431\u044B\u0432\u0430\u043B\u0438 \u0432 \u0430\u0440\u0445\u0438\u0432\u0435?"
      answerText: "\u041F\u0430\u0440\u0443 \u0440\u0430\u0437, \u043F\u043E \u0440\u0430\u0431\u043E\u0442\u0435.
        \u041D\u0438\u0447\u0435\u0433\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0433\u043E."
      isLie: 1
      truthText: "\u0413\u043B\u0443\u043C\u043E\u0432 \u0431\u044B\u043B \u0442\u0430\u043C
        \u0437\u0430 \u043D\u0435\u0434\u0435\u043B\u044E \u0434\u043E \u043F\u043E\u0436\u0430\u0440\u0430,
        \u0437\u0430\u0431\u0438\u0440\u0430\u043B \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B."
      revealedFragmentId: c3_frag_glumov_visited
    - questionText: "\u041A\u0430\u043A\u0438\u0435 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
        \u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C \u0432 \u0441\u0433\u043E\u0440\u0435\u0432\u0448\u0435\u043C
        \u043A\u0440\u044B\u043B\u0435?"
      answerText: "\u041E\u0442\u043A\u0443\u0434\u0430 \u043C\u043D\u0435 \u0437\u043D\u0430\u0442\u044C?
        \u042F \u043D\u0435 \u0430\u0440\u0445\u0438\u0432\u0430\u0440\u0438\u0443\u0441."
      isLie: 1
      truthText: "\u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u043C
        \u043A\u0440\u044B\u043B\u0435 \u2014 \u043A\u0430\u0434\u0430\u0441\u0442\u0440\u043E\u0432\u044B\u0435
        \u0434\u0435\u043B\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0413\u043B\u0443\u043C\u043E\u0432
        \u043F\u043E\u0434\u0434\u0435\u043B\u0430\u043B."
      revealedFragmentId: c3_frag_cadastre_wing
  - targetPersonId: fomina
    questions:
    - questionText: "\u0427\u0442\u043E \u0432\u044B \u0432\u0438\u0434\u0435\u043B\u0438
        \u043A\u043E\u0433\u0434\u0430 \u0432\u0435\u0440\u043D\u0443\u043B\u0438\u0441\u044C?"
      answerText: "\u041E\u0433\u043E\u043D\u044C \u0448\u0451\u043B \u0438\u0437
        \u043A\u0430\u0434\u0430\u0441\u0442\u0440\u043E\u0432\u043E\u0433\u043E
        \u043A\u0440\u044B\u043B\u0430. \u041F\u0430\u0445\u043B\u043E \u0431\u0435\u043D\u0437\u0438\u043D\u043E\u043C.
        \u042F \u043F\u044B\u0442\u0430\u043B\u0430\u0441\u044C \u0441\u043F\u0430\u0441\u0442\u0438
        \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B... \u043E\u0431\u043E\u0436\u0433\u043B\u0430\u0441\u044C."
      isLie: 0
      truthText: 
      revealedFragmentId: c3_frag_gasoline_smell
    - questionText: "\u041A\u0442\u043E \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
        \u0432\u0440\u0435\u043C\u044F \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
        \u043A\u0430\u0434\u0430\u0441\u0442\u0440\u043E\u0432\u044B\u043C\u0438
        \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043C\u0438?"
      answerText: "\u0413\u043B\u0443\u043C\u043E\u0432 \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u043B
        \u043D\u0435\u0434\u0435\u043B\u044E \u043D\u0430\u0437\u0430\u0434. \u041F\u0440\u043E\u0441\u0438\u043B
        \u0434\u0435\u043B\u043E \u043F\u043E \u0443\u0447\u0430\u0441\u0442\u043A\u0430\u043C
        \u043D\u0430 \u041E\u0437\u0451\u0440\u043D\u043E\u0439. \u042F \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0430
        \u2014 \u043D\u0443\u0436\u0435\u043D \u0437\u0430\u043F\u0440\u043E\u0441."
      isLie: 0
      truthText: 
      revealedFragmentId: c3_frag_glumov_request
  - targetPersonId: belov
    questions:
    - questionText: "\u0412\u0430\u0448\u0430 \u0441\u0442\u0440\u043E\u0439\u043A\u0430
        \u043D\u0430 \u041E\u0437\u0451\u0440\u043D\u043E\u0439 \u2014 \u0437\u0430\u043A\u043E\u043D\u043D\u0430?"
      answerText: "\u0412\u0441\u0435 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u044F
        \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u044B \u0447\u0435\u0440\u0435\u0437
        \u0437\u0435\u043C\u0435\u043B\u044C\u043D\u044B\u0439 \u043A\u043E\u043C\u0438\u0442\u0435\u0442.
        \u0413\u043B\u0443\u043C\u043E\u0432 \u043B\u0438\u0447\u043D\u043E \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043B."
      isLie: 0
      truthText: 
      revealedFragmentId: c3_frag_permits
    - questionText: "\u0412\u044B \u0437\u043D\u0430\u043B\u0438 \u0447\u0442\u043E
        \u0432 \u0430\u0440\u0445\u0438\u0432\u0435 \u0435\u0441\u0442\u044C \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
        \u043F\u043E \u0432\u0430\u0448\u0438\u043C \u0443\u0447\u0430\u0441\u0442\u043A\u0430\u043C?"
      answerText: "\u041D\u0435\u0442. \u041C\u0435\u043D\u044F \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u0435\u0442
        \u0441\u0442\u0440\u043E\u0439\u043A\u0430, \u0430 \u043D\u0435 \u0431\u0443\u043C\u0430\u0436\u043A\u0438."
      isLie: 1
      truthText: "\u0411\u0435\u043B\u043E\u0432 \u0437\u043D\u0430\u043B \u2014
        \u0413\u043B\u0443\u043C\u043E\u0432 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0434\u0438\u043B
        \u0435\u0433\u043E."
      revealedFragmentId: c3_frag_belov_knew
  - targetPersonId: rita
    questions:
    - questionText: "\u0412\u044B \u0437\u0430\u043C\u0435\u0447\u0430\u043B\u0438
        \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435 \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435
        \u0413\u043B\u0443\u043C\u043E\u0432\u0430?"
      answerText: "\u041D\u0435\u0442, \u0432\u0441\u0451 \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u043E."
      isLie: 1
      truthText: "\u0413\u043B\u0443\u043C\u043E\u0432 \u0431\u044B\u043B \u043A\u0440\u0430\u0439\u043D\u0435
        \u043D\u0435\u0440\u0432\u043D\u044B\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
        \u043C\u0435\u0441\u044F\u0446. \u0417\u0432\u043E\u043D\u0438\u043B \u043A\u043E\u043C\u0443-\u0442\u043E
        \xAB\u043D\u0430\u0441\u0447\u0451\u0442 \u0430\u0440\u0445\u0438\u0432\u0430\xBB."
      revealedFragmentId: c3_frag_rita_covers
    - questionText: "\u0413\u043B\u0443\u043C\u043E\u0432 \u0434\u0430\u0432\u0430\u043B
        \u0432\u0430\u043C \u043A\u0430\u043A\u0438\u0435-\u043D\u0438\u0431\u0443\u0434\u044C
        \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u044F, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435
        \u0441 \u0430\u0440\u0445\u0438\u0432\u043E\u043C?"
      answerText: "\u041D\u0435\u0442... \u041D\u0443, \u043E\u0434\u0438\u043D \u0440\u0430\u0437
        \u043F\u0440\u043E\u0441\u0438\u043B \u0443\u0437\u043D\u0430\u0442\u044C
        \u0433\u0440\u0430\u0444\u0438\u043A \u0440\u0430\u0431\u043E\u0442\u044B
        \u0430\u0440\u0445\u0438\u0432\u0430. \u041A\u043E\u0433\u0434\u0430 \u043E\u043D
        \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F."
      isLie: 0
      truthText: 
      revealedFragmentId: c3_frag_schedule
  locations:
  - locationId: archive
    displayName: "\u0420\u0443\u0438\u043D\u044B \u0430\u0440\u0445\u0438\u0432\u0430"
    description: "\u0421\u0433\u043E\u0440\u0435\u0432\u0448\u0435\u0435 \u043A\u0440\u044B\u043B\u043E.
      \u0421\u0442\u0435\u043B\u043B\u0430\u0436\u0438 \u043E\u0431\u0440\u0443\u0448\u0438\u043B\u0438\u0441\u044C.
      \u0417\u0430\u043F\u0430\u0445 \u0433\u0430\u0440\u0438."
    zones:
    - zoneName: "\u041E\u0447\u0430\u0433 \u0432\u043E\u0437\u0433\u043E\u0440\u0430\u043D\u0438\u044F"
      description: "\u0422\u0440\u0438 \u0442\u043E\u0447\u043A\u0438 \u043F\u043E\u0434\u0436\u043E\u0433\u0430.
        \u041A\u0430\u043D\u0438\u0441\u0442\u0440\u0430 \u0438\u0437-\u043F\u043E\u0434
        \u0431\u0435\u043D\u0437\u0438\u043D\u0430 \u0432 \u0443\u0433\u043B\u0443
        \u2014 \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u043E\u043F\u043B\u0430\u0432\u043B\u0435\u043D\u0430,
        \u043D\u043E \u0441\u0435\u0440\u0438\u0439\u043D\u044B\u0439 \u043D\u043E\u043C\u0435\u0440
        \u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F."
      revealedFragmentId: c3_frag_canister
    - zoneName: "\u0421\u0442\u0435\u043B\u043B\u0430\u0436\u0438"
      description: "\u041A\u0430\u0434\u0430\u0441\u0442\u0440\u043E\u0432\u044B\u0435
        \u0434\u0435\u043B\u0430 \u0437\u0430 2018-2023 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
        \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u044B. \u0418\u043C\u0435\u043D\u043D\u043E
        \u0443\u0447\u0430\u0441\u0442\u043A\u0438 \u041E\u0437\u0451\u0440\u043D\u043E\u0433\u043E
        \u0440\u0430\u0439\u043E\u043D\u0430."
      revealedFragmentId: c3_frag_targeted_docs
    - zoneName: "\u0417\u0430\u043F\u0430\u0441\u043D\u043E\u0439 \u0432\u044B\u0445\u043E\u0434"
      description: "\u0417\u0430\u043C\u043E\u043A \u0441\u043B\u043E\u043C\u0430\u043D
        \u0441\u043D\u0430\u0440\u0443\u0436\u0438. \u0421\u0432\u0435\u0436\u0438\u0435
        \u0441\u043B\u0435\u0434\u044B \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430."
      revealedFragmentId: c3_frag_broken_lock
  - locationId: parking_a
    displayName: "\u041F\u0430\u0440\u043A\u043E\u0432\u043A\u0430 \u0443 \u0430\u0440\u0445\u0438\u0432\u0430"
    description: "\u041A\u0430\u043C\u0435\u0440\u0430 \u043D\u0430 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u043C
      \u0437\u0434\u0430\u043D\u0438\u0438 \u0437\u0430\u0441\u043D\u044F\u043B\u0430
      \u043F\u0430\u0440\u043A\u043E\u0432\u043A\u0443 \u043D\u043E\u0447\u044C\u044E."
    zones:
    - zoneName: "\u0417\u0430\u043F\u0438\u0441\u044C \u043A\u0430\u043C\u0435\u0440\u044B"
      description: "\u0412 02:40 \u043D\u0430 \u043F\u0430\u0440\u043A\u043E\u0432\u043A\u0443
        \u0437\u0430\u0435\u0445\u0430\u043B \u0442\u0451\u043C\u043D\u044B\u0439
        \u0441\u0435\u0434\u0430\u043D. \u041D\u043E\u043C\u0435\u0440 \u043D\u0435\u0447\u0438\u0442\u0430\u0435\u043C.
