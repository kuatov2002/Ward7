  - locationId: office_r
    displayName: "\u041A\u0430\u0431\u0438\u043D\u0435\u0442 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0449\u0435\u0433\u043E"
    description: "\u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u043A\u0430\u0431\u0438\u043D\u0435\u0442
      \u0437\u0430 \u043A\u0443\u0445\u043D\u0435\u0439. \u0411\u0443\u043C\u0430\u0433\u0438,
      \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440, \u0441\u0435\u0439\u0444."
    zones:
    - zoneName: "\u0411\u0443\u043C\u0430\u0433\u0438 \u043D\u0430 \u0441\u0442\u043E\u043B\u0435"
      description: "\u0424\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435
        \u043E\u0442\u0447\u0451\u0442\u044B. \u0420\u0435\u0441\u0442\u043E\u0440\u0430\u043D
        \u0432 \u043C\u0438\u043D\u0443\u0441\u0435 3 \u043C\u0435\u0441\u044F\u0446\u0430
        \u043F\u043E\u0434\u0440\u044F\u0434. \u0411\u0430\u043D\u043A \u0442\u0440\u0435\u0431\u0443\u0435\u0442
        \u043F\u043E\u0433\u0430\u0448\u0435\u043D\u0438\u044F \u043A\u0440\u0435\u0434\u0438\u0442\u0430."
      revealedFragmentId: c2_frag_debt
    - zoneName: "\u041A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440"
      description: "\u041E\u0442\u043A\u0440\u044B\u0442\u0430 \u043F\u043E\u0447\u0442\u0430
        \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u043E\u0439. \u041F\u0438\u0441\u044C\u043C\u043E
        \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043E\u0439: \xAB\u041F\u043E\u043B\u0438\u0441
        \u043D\u0430 \u0436\u0438\u0437\u043D\u044C \u041B\u0443\u043D\u0451\u0432\u0430
        \u0413.\u0410., \u0441\u0443\u043C\u043C\u0430 8 000 000 \u0440\u0443\u0431.\xBB"
