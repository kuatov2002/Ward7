    - zoneName: "\u041C\u0443\u0441\u043E\u0440\u043D\u043E\u0435 \u0432\u0435\u0434\u0440\u043E"
      description: "\u041F\u0443\u0441\u0442\u043E\u0439 \u043F\u0430\u043A\u0435\u0442\u0438\u043A
        \u0431\u0435\u0437 \u043C\u0430\u0440\u043A\u0438\u0440\u043E\u0432\u043A\u0438.
        \u0412\u043D\u0443\u0442\u0440\u0438 \u2014 \u043E\u0441\u0442\u0430\u0442\u043A\u0438
        \u0431\u0435\u043B\u043E\u0433\u043E \u043F\u043E\u0440\u043E\u0448\u043A\u0430."
