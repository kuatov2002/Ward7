  correctOpportunityId: c2_frag_spice_delivery
  correctEvidenceId: c2_frag_powder
  correctSuspectId: c2_frag_suspect_kravtsova
  briefingText: "\u0428\u0435\u0444-\u043F\u043E\u0432\u0430\u0440 \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0430
    \xAB\u041A\u0430\u0448\u0442\u0430\u043D\xBB \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439
    \u041B\u0443\u043D\u0451\u0432 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438
    \u043D\u043E\u0432\u043E\u0433\u043E \u043C\u0435\u043D\u044E. \u041F\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043F\u0440\u0438\u0447\u0438\u043D\u0430 \u2014 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435.
    \u041D\u0430 \u043A\u0443\u0445\u043D\u0435 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0447\u0435\u0442\u0432\u0435\u0440\u043E. \u0420\u0435\u0441\u0442\u043E\u0440\u0430\u043D
    \u0437\u0430\u043A\u0440\u044B\u0442, \u0432\u0441\u0435 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u0438
    \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438 \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043D\u044B
    \u0434\u043B\u044F \u043E\u043F\u0440\u043E\u0441\u0430."
  consequenceCorrectArrest:
    headlineText: "\u0410\u0420\u0415\u0421\u0422 \u041A\u0420\u0410\u0412\u0426\u041E\u0412\u041E\u0419:
      \u0421\u043E\u0432\u043B\u0430\u0434\u0435\u043B\u0438\u0446\u0430 \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0430
      \xAB\u041A\u0430\u0448\u0442\u0430\u043D\xBB \u043E\u0442\u0440\u0430\u0432\u0438\u043B\u0430
      \u0448\u0435\u0444-\u043F\u043E\u0432\u0430\u0440\u0430 \u0440\u0430\u0434\u0438
      \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0438"
    detailText: "\u042D\u043A\u0441\u043F\u0435\u0440\u0442\u0438\u0437\u0430 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u0430
      \u0442\u0430\u043B\u043B\u0438\u0439 \u0432 \u0441\u043F\u0435\u0446\u0438\u044F\u0445.
      \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430 \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043D\u0430
      \u043F\u0440\u0438 \u043F\u043E\u043F\u044B\u0442\u043A\u0435 \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0438\u0442\u044C
      \u043F\u043E\u043B\u0438\u0441."
  consequenceWrongArrest:
    headlineText: "\u041E\u0428\u0418\u0411\u041A\u0410 \u0421\u041B\u0415\u0414\u0421\u0422\u0412\u0418\u042F:
      \u0410\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D \u043D\u0435\u0432\u0438\u043D\u043E\u0432\u043D\u044B\u0439.
      \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430 \u043F\u043E\u043A\u0438\u043D\u0443\u043B\u0430
      \u0441\u0442\u0440\u0430\u043D\u0443."
    detailText: "\u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F \u043E\u0442\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
      \u0441\u043A\u0440\u044B\u043B\u0430\u0441\u044C. \u0421\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0430
      \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0435\u043D\u0430 \u0447\u0435\u0440\u0435\u0437
      \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u043D\u043E\u0435 \u043B\u0438\u0446\u043E."
  consequenceUnsolved:
    headlineText: "\u0414\u0415\u041B\u041E \u0417\u0410\u041A\u0420\u042B\u0422\u041E:
      \u0421\u043C\u0435\u0440\u0442\u044C \u0448\u0435\u0444-\u043F\u043E\u0432\u0430\u0440\u0430
      \u0441\u043F\u0438\u0441\u0430\u043D\u0430 \u043D\u0430 \xAB\u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u044B\u0439
      \u0441\u043B\u0443\u0447\u0430\u0439\xBB."
    detailText: "\u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
      \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0430. \u0420\u0435\u0441\u0442\u043E\u0440\u0430\u043D
      \u0437\u0430\u043A\u0440\u044B\u0442, \u043D\u043E \u0432\u0438\u043D\u043E\u0432\u043D\u044B\u0445
      \u043D\u0435\u0442."
  consequenceWeakCase:
    headlineText: "\u041E\u041F\u0420\u0410\u0412\u0414\u0410\u041D\u0418\u0415:
      \u0410\u0434\u0432\u043E\u043A\u0430\u0442 \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u043E\u0439
      \u0434\u043E\u0431\u0438\u043B\u0441\u044F \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u044F
      \u2014 \u0443\u043B\u0438\u043A \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E."
    detailText: "\u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430 \u043D\u0430 \u0441\u0432\u043E\u0431\u043E\u0434\u0435.
      \u041F\u043E\u043B\u0438\u0441 \u0437\u0430\u043C\u043E\u0440\u043E\u0436\u0435\u043D,
      \u043D\u043E \u043E\u043D\u0430 \u043F\u043B\u0430\u043D\u0438\u0440\u0443\u0435\u0442
      \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u0443\u044E \u043F\u043E\u043F\u044B\u0442\u043A\u0443
      \u0432\u0437\u044B\u0441\u043A\u0430\u043D\u0438\u044F."
