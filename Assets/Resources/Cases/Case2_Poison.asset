  caseId: case_poison
  displayName: "\u041E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0432
    \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0435"
  caseNumber: 2
  totalMoves: 8
  trueCulpritId: kravtsova
  persons:
  - personId: kravtsova
    displayName: "\u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430 \u041D.\u0414."
    role: 0
    hiddenAgenda: 2
    description: "\u0421\u043E\u0432\u043B\u0430\u0434\u0435\u043B\u0438\u0446\u0430
      \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0430, 38 \u043B\u0435\u0442.
      \u0421\u043F\u043E\u043A\u043E\u0439\u043D\u0430. \u0413\u043E\u0432\u043E\u0440\u0438\u0442
      \u0447\u0442\u043E \u041B\u0443\u043D\u0451\u0432 \u0431\u044B\u043B \u0435\u0451
      \u0434\u0440\u0443\u0433\u043E\u043C."
  - personId: taras
    displayName: "\u0422\u0430\u0440\u0430\u0441 \u0428\u0443\u043B\u044C\u0433\u0430"
    role: 0
    hiddenAgenda: 3
    description: "\u0421\u0443-\u0448\u0435\u0444, 29 \u043B\u0435\u0442. \u0410\u043C\u0431\u0438\u0446\u0438\u043E\u0437\u043D\u044B\u0439.
      \u0425\u043E\u0442\u0435\u043B \u0437\u0430\u043D\u044F\u0442\u044C \u043C\u0435\u0441\u0442\u043E
      \u041B\u0443\u043D\u0451\u0432\u0430."
  - personId: diana
    displayName: "\u0414\u0438\u0430\u043D\u0430 \u0420\u043E\u043A\u043E\u0442\u043E\u0432\u0430"
    role: 1
    hiddenAgenda: 0
    description: "\u0421\u043E\u043C\u0435\u043B\u044C\u0435, \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      3 \u0433\u043E\u0434\u0430. \u041F\u043E\u0434\u0430\u0432\u0430\u043B\u0430
      \u0432\u0438\u043D\u043E \u043A \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438."
  - personId: efimov
    displayName: "\u0415\u0444\u0438\u043C\u043E\u0432 \u0420.\u0421."
    role: 1
    hiddenAgenda: 1
    description: "\u0420\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u043D\u044B\u0439
      \u043A\u0440\u0438\u0442\u0438\u043A, \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0451\u043D
      \u043D\u0430 \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u044E.
      \u0417\u043D\u0430\u043A\u043E\u043C\u044B\u0439 \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u043E\u0439."
  interrogations:
  - targetPersonId: kravtsova
    questions:
    - questionText: "\u041A\u0430\u043A\u043E\u0432\u044B \u0432\u0430\u0448\u0438
        \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u041B\u0443\u043D\u0451\u0432\u044B\u043C?"
      answerText: "\u0414\u0435\u043B\u043E\u0432\u044B\u0435 \u043F\u0430\u0440\u0442\u043D\u0451\u0440\u044B
        \u0438 \u0434\u0440\u0443\u0437\u044C\u044F. \u042F \u0432\u043B\u043E\u0436\u0438\u043B\u0430
        \u0432 \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D \u0432\u0441\u0451
        \u0447\u0442\u043E \u0438\u043C\u0435\u043B\u0430."
      isLie: 1
      truthText: "\u0420\u0435\u0441\u0442\u043E\u0440\u0430\u043D \u0443\u0431\u044B\u0442\u043E\u0447\u0435\u043D.
        \u041B\u0443\u043D\u0451\u0432 \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
        \u043C\u0435\u043D\u044F\u0442\u044C \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E."
      revealedFragmentId: c2_frag_partnership
    - questionText: "\u041A\u0442\u043E \u0433\u043E\u0442\u043E\u0432\u0438\u043B
        \u0431\u043B\u044E\u0434\u0430 \u0434\u043B\u044F \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438?"
      answerText: "\u041B\u0443\u043D\u0451\u0432 \u043B\u0438\u0447\u043D\u043E.
        \u0422\u0430\u0440\u0430\u0441 \u043F\u043E\u043C\u043E\u0433\u0430\u043B
        \u0441 \u0441\u043E\u0443\u0441\u0430\u043C\u0438. \u042F \u043D\u0435 \u0437\u0430\u0445\u043E\u0434\u0438\u043B\u0430
        \u043D\u0430 \u043A\u0443\u0445\u043D\u044E."
      isLie: 1
      truthText: "\u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430 \u0431\u044B\u043B\u0430
        \u043D\u0430 \u043A\u0443\u0445\u043D\u0435 \u0438 \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u043B\u0430
        \u0441\u043F\u0435\u0446\u0438\u0438 \u0432 \u043E\u0434\u043D\u043E \u0438\u0437
        \u0431\u043B\u044E\u0434."
      revealedFragmentId: c2_frag_kitchen_lie
    - questionText: "\u041A\u043E\u043C\u0443 \u0432\u044B\u0433\u043E\u0434\u043D\u0430
        \u0441\u043C\u0435\u0440\u0442\u044C \u041B\u0443\u043D\u0451\u0432\u0430?"
      answerText: "\u041D\u0438\u043A\u043E\u043C\u0443. \u041B\u0443\u043D\u0451\u0432
        \u2014 \u043B\u0438\u0446\u043E \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0430.
        \u0411\u0435\u0437 \u043D\u0435\u0433\u043E \u043C\u044B \u0437\u0430\u043A\u0440\u043E\u0435\u043C\u0441\u044F."
      isLie: 1
      truthText: "\u0421\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0430 \u043D\u0430
        \u041B\u0443\u043D\u0451\u0432\u0430 \u2014 8 \u043C\u043B\u043D. \u041F\u043E\u043B\u0443\u0447\u0430\u0442\u0435\u043B\u044C
        \u2014 \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430."
      revealedFragmentId: c2_frag_insurance_motive
  - targetPersonId: taras
    questions:
    - questionText: "\u0412\u044B \u0445\u043E\u0442\u0435\u043B\u0438 \u0441\u0442\u0430\u0442\u044C
        \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0448\u0435\u0444\u043E\u043C?"
      answerText: "\u0414\u0430, \u043D\u0435 \u0441\u043A\u0440\u044B\u0432\u0430\u044E.
        \u041D\u043E \u043D\u0435 \u0446\u0435\u043D\u043E\u0439 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0430.
        \u041B\u0443\u043D\u0451\u0432 \u043E\u0431\u0435\u0449\u0430\u043B \u0443\u0439\u0442\u0438
        \u0447\u0435\u0440\u0435\u0437 \u0433\u043E\u0434."
      isLie: 0
      truthText: 
      revealedFragmentId: c2_frag_taras_ambition
    - questionText: "\u041A\u0442\u043E \u0438\u043C\u0435\u043B \u0434\u043E\u0441\u0442\u0443\u043F
        \u043A \u0438\u043D\u0433\u0440\u0435\u0434\u0438\u0435\u043D\u0442\u0430\u043C?"
      answerText: "\u042F, \u041B\u0443\u043D\u0451\u0432 \u0438 \u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430.
        \u041E\u043D\u0430 \u0437\u0430\u0445\u043E\u0434\u0438\u043B\u0430 \u0443\u0442\u0440\u043E\u043C,
        \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0441\u043F\u0435\u0446\u0438\u0438
        \u043E\u0442 \u043F\u043E\u0441\u0442\u0430\u0432\u0449\u0438\u043A\u0430."
      isLie: 0
      truthText: 
      revealedFragmentId: c2_frag_spice_delivery
  - targetPersonId: diana
    questions:
    - questionText: "\u0412\u044B \u0432\u0438\u0434\u0435\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E
        \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0435?"
      answerText: "\u041A\u0440\u0430\u0432\u0446\u043E\u0432\u0430 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
        \u0441\u043F\u0435\u0446\u0438\u0438 \u0432 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u043C
        \u043F\u0430\u043A\u0435\u0442\u0435. \u041E\u0431\u044B\u0447\u043D\u043E
        \u043F\u043E\u0441\u0442\u0430\u0432\u0449\u0438\u043A \u043F\u0440\u0438\u0432\u043E\u0437\u0438\u0442
        \u0441\u0430\u043C."
      isLie: 0
      truthText: 
      revealedFragmentId: c2_frag_diana_saw
    - questionText: "\u041A\u0430\u043A \u0441\u0435\u0431\u044F \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
        \u041B\u0443\u043D\u0451\u0432 \u0434\u043E \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438?"
      answerText: "\u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E. \u041D\u043E
        \u043F\u043E\u0441\u043B\u0435 \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
        \u0431\u043B\u044E\u0434\u0430 \u043F\u043E\u0431\u043B\u0435\u0434\u043D\u0435\u043B.
        \u042F \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u0441\u043A\u043E\u0440\u0443\u044E."
      isLie: 0
      truthText: 
      revealedFragmentId: c2_frag_third_dish
  locations:
  - locationId: kitchen
    displayName: "\u041A\u0443\u0445\u043D\u044F \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0430"
    description: "\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
