  suspectId: suspect_02
  displayName: "\u0415\u043B\u0435\u043D\u0430 \u0420\u0438\u0432\u0435\u0440\u0430"
  weekNumber: 2
  isGuilty: 1
  dossierText: "\u0415\u043B\u0435\u043D\u0430 \u0420\u0438\u0432\u0435\u0440\u0430,
    38 \u043B\u0435\u0442. \u041E\u0431\u0432\u0438\u043D\u044F\u0435\u0442\u0441\u044F
    \u0432 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438 \u043C\u0443\u0436\u0430
    \u0410\u043D\u0434\u0440\u0435\u044F \u0420\u0438\u0432\u0435\u0440\u044B (52
    \u0433\u043E\u0434\u0430). \u0421\u043C\u0435\u0440\u0442\u044C \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B\u0430
    \u043E\u0442 \u043E\u0441\u0442\u0440\u043E\u0439 \u043F\u043E\u0447\u0435\u0447\u043D\u043E\u0439
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438.
    \u0412 \u0442\u043A\u0430\u043D\u044F\u0445 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D
    \u044D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044C
    \u2014 \u043A\u043E\u043C\u043F\u043E\u043D\u0435\u043D\u0442 \u0430\u043D\u0442\u0438\u0444\u0440\u0438\u0437\u0430.\r\n\r\n\u0420\u0438\u0432\u0435\u0440\u0430
    \u2014 \u043C\u0435\u0434\u0441\u0435\u0441\u0442\u0440\u0430, \u0441\u0442\u0430\u0436
    14 \u043B\u0435\u0442. \u0417\u043D\u0430\u0435\u0442 \u0444\u0430\u0440\u043C\u0430\u043A\u043E\u043B\u043E\u0433\u0438\u044E,
    \u0434\u043E\u0437\u0438\u0440\u043E\u0432\u043A\u0438, \u043A\u043B\u0438\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u0430\u0440\u0442\u0438\u043D\u0443. \u0411\u0440\u0430\u043A \u0441 \u0410\u043D\u0434\u0440\u0435\u0435\u043C
    \u2014 8 \u043B\u0435\u0442. \u0410\u043D\u0434\u0440\u0435\u0439 \u2014 \u0432\u043B\u0430\u0434\u0435\u043B\u0435\u0446
    \u0430\u0432\u0442\u043E\u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439,
    \u0437\u043B\u043E\u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u044F\u043B
    \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0435\u043C. \u0421\u043E\u0441\u0435\u0434\u0438
    \u043D\u0435\u043E\u0434\u043D\u043E\u043A\u0440\u0430\u0442\u043D\u043E \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u0438
    \u043F\u043E\u043B\u0438\u0446\u0438\u044E \u0438\u0437-\u0437\u0430 \u0448\u0443\u043C\u0430.\r\n\r\n\u0421\u0442\u0440\u0430\u0445\u043E\u0432\u043E\u0439
    \u043F\u043E\u043B\u0438\u0441 \u043D\u0430 \u0436\u0438\u0437\u043D\u044C \u0410\u043D\u0434\u0440\u0435\u044F
    \u2014 $800 000, \u0431\u0435\u043D\u0435\u0444\u0438\u0446\u0438\u0430\u0440
    \u2014 \u0415\u043B\u0435\u043D\u0430. \u041E\u0444\u043E\u0440\u043C\u043B\u0435\u043D
    \u0437\u0430 \u0434\u0432\u0430 \u043C\u0435\u0441\u044F\u0446\u0430 \u0434\u043E
    \u0441\u043C\u0435\u0440\u0442\u0438. \u0418\u043D\u0438\u0446\u0438\u0430\u0442\u043E\u0440
    \u043E\u0444\u043E\u0440\u043C\u043B\u0435\u043D\u0438\u044F \u043D\u0435 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D.\r\n\r\n\u0423
    \u0415\u043B\u0435\u043D\u044B \u043D\u043E\u0432\u044B\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0414\u043C\u0438\u0442\u0440\u0438\u0435\u043C \u041E\u0440\u043B\u043E\u0432\u044B\u043C
    (34 \u0433\u043E\u0434\u0430, \u0444\u0438\u0442\u043D\u0435\u0441-\u0442\u0440\u0435\u043D\u0435\u0440).
    \u0417\u043D\u0430\u043A\u043E\u043C\u044B \u0442\u0440\u0438 \u043C\u0435\u0441\u044F\u0446\u0430.
    \u041E\u0440\u043B\u043E\u0432 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442
    \u0447\u0442\u043E \u0415\u043B\u0435\u043D\u0430 \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0440\u0430\u0437\u0432\u043E\u0434.\r\n\r\n\u0410\u043D\u0434\u0440\u0435\u0439
    \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0441\u044F \u043D\u0430 \u0442\u043E\u0448\u043D\u043E\u0442\u0443
    \u0438 \u0431\u043E\u043B\u0438 \u0432 \u0436\u0438\u0432\u043E\u0442\u0435 \u0437\u0430
    \u0434\u0432\u0435 \u043D\u0435\u0434\u0435\u043B\u0438 \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438.
    \u041A \u0432\u0440\u0430\u0447\u0443 \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u043E\u0434\u0438\u043D \u0440\u0430\u0437 \u2014 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u044B
    \u0430\u043D\u0430\u043B\u0438\u0437\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043D\u0435 \u0441\u0434\u0430\u043B.\r\n\r\n\u0412 \u0433\u0430\u0440\u0430\u0436\u0435
    \u0420\u0438\u0432\u0435\u0440\u044B \u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C
    \u043A\u0430\u043D\u0438\u0441\u0442\u0440\u0430 \u0430\u043D\u0442\u0438\u0444\u0440\u0438\u0437\u0430
    \u2014 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0430\u044F \u0434\u043B\u044F
    \u0430\u0432\u0442\u043E\u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439.
    \u041D\u0430 \u043A\u0443\u0445\u043D\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0430
    \u043F\u043E\u0447\u0430\u0442\u0430\u044F \u0431\u0443\u0442\u044B\u043B\u043A\u0430
    \u0432\u0438\u0441\u043A\u0438 \u2014 \u0410\u043D\u0434\u0440\u0435\u0439 \u043F\u0438\u043B
    \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E."
  contacts:
  - contactId: c2_marina
    displayName: "\u041C\u0430\u0440\u0438\u043D\u0430 \u0421\u043E\u0442\u043D\u0438\u043A\u043E\u0432\u0430
      (\u043F\u043E\u0434\u0440\u0443\u0433\u0430 \u0415\u043B\u0435\u043D\u044B)"
    response: "\xAB\u0415\u043B\u0435\u043D\u0430 \u2014 \u0441\u0432\u044F\u0442\u0430\u044F
      \u0436\u0435\u043D\u0449\u0438\u043D\u0430. \u0410\u043D\u0434\u0440\u0435\u0439
      \u043F\u0438\u043B, \u043E\u0440\u0430\u043B, \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B
      \u0440\u0443\u043A\u0443. \u041E\u043D\u0430 \u0442\u0435\u0440\u043F\u0435\u043B\u0430
      \u0432\u043E\u0441\u0435\u043C\u044C \u043B\u0435\u0442. \u0421\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0430?
      \u041A\u043E\u043D\u0435\u0447\u043D\u043E \u043E\u0444\u043E\u0440\u043C\u0438\u043B\u0430
      \u2014 \u0431\u043E\u044F\u043B\u0430\u0441\u044C \u0447\u0442\u043E \u043E\u043D
      \u0440\u0430\u0437\u043E\u0431\u044C\u0451\u0442\u0441\u044F \u043F\u044C\u044F\u043D\u044B\u0439
      \u0438 \u043E\u043D\u0430 \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
      \u043D\u0438 \u0441 \u0447\u0435\u043C. \u042D\u0442\u043E \u0437\u0434\u0440\u0430\u0432\u044B\u0439
      \u0441\u043C\u044B\u0441\u043B, \u0430 \u043D\u0435 \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435.\xBB"
  - contactId: c2_orlov
    displayName: "\u0414\u043C\u0438\u0442\u0440\u0438\u0439 \u041E\u0440\u043B\u043E\u0432
      (\u043D\u043E\u0432\u044B\u0439 \u043F\u0430\u0440\u0442\u043D\u0451\u0440)"
    response: "\xAB\u041C\u044B \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u043C\u0441\u044F
      \u0442\u0440\u0438 \u043C\u0435\u0441\u044F\u0446\u0430. \u0415\u043B\u0435\u043D\u0430
      \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B\u0430 \u043F\u043E\u0434\u0430\u0442\u044C
      \u043D\u0430 \u0440\u0430\u0437\u0432\u043E\u0434 \u043F\u043E\u0441\u043B\u0435
      \u041D\u043E\u0432\u043E\u0433\u043E \u0433\u043E\u0434\u0430. \u041E\u043D\u0430
      \u043D\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0430 \u043D\u0430
      \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E \u2014 \u0432\u044B \u0435\u0451
      \u043D\u0435 \u0437\u043D\u0430\u0435\u0442\u0435. \u041D\u043E... \u043E\u043D\u0430
      \u043E\u0434\u043D\u0430\u0436\u0434\u044B \u0441\u043A\u0430\u0437\u0430\u043B\u0430:
      '\u0421\u043A\u043E\u0440\u043E \u0432\u0441\u0451 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u0441\u044F.'
      \u042F \u0440\u0435\u0448\u0438\u043B \u0447\u0442\u043E \u043E\u043D\u0430
      \u043F\u0440\u043E \u0440\u0430\u0437\u0432\u043E\u0434.\xBB"
  - contactId: c2_victoria
    displayName: "\u0412\u0438\u043A\u0442\u043E\u0440\u0438\u044F \u0420\u0438\u0432\u0435\u0440\u0430
      (\u0434\u043E\u0447\u044C \u0410\u043D\u0434\u0440\u0435\u044F \u043E\u0442
      \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0431\u0440\u0430\u043A\u0430)"
    response: "\xAB\u0415\u043B\u0435\u043D\u0430 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B\u0430
      \u043E\u0442\u0446\u0430. \u042F \u0432\u0438\u0434\u0435\u043B\u0430 \u043A\u0430\u043A
      \u043E\u043D\u0430 \u043F\u043E\u043A\u0443\u043F\u0430\u043B\u0430 \u0430\u043D\u0442\u0438\u0444\u0440\u0438\u0437
      \u0432 \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
      \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0435 \u0437\u0430 \u043D\u0435\u0434\u0435\u043B\u044E
      \u0434\u043E \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. \u0421\u043A\u0430\u0437\u0430\u043B\u0430
      \u2014 \u0434\u043B\u044F \u043C\u0430\u0448\u0438\u043D\u044B \u043F\u043E\u0434\u0440\u0443\u0433\u0438.
      \u041D\u043E \u0443 \u041C\u0430\u0440\u0438\u043D\u044B \u043D\u0435\u0442
      \u043C\u0430\u0448\u0438\u043D\u044B. \u042F \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B\u0430.\xBB"
  - contactId: c2_doctor
    displayName: "\u0414\u043E\u043A\u0442\u043E\u0440 \u0421\u0435\u043C\u0451\u043D\u043E\u0432
      (\u043B\u0435\u0447\u0430\u0449\u0438\u0439 \u0432\u0440\u0430\u0447)"
    response: "\xAB\u0410\u043D\u0434\u0440\u0435\u0439 \u043F\u0440\u0438\u0448\u0451\u043B
      \u0441 \u0436\u0430\u043B\u043E\u0431\u0430\u043C\u0438 \u043D\u0430 \u0442\u043E\u0448\u043D\u043E\u0442\u0443,
      \u0433\u043E\u043B\u043E\u0432\u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0435,
      \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u043F\u0440\u0438\u0432\u043A\u0443\u0441. \u042F \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B
      \u043F\u043E\u043B\u043D\u044B\u0439 \u0431\u0438\u043E\u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0430\u043D\u0430\u043B\u0438\u0437. \u041E\u043D \u043D\u0435 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F.
      \u0415\u0441\u043B\u0438 \u0431\u044B \u0441\u0434\u0430\u043B \u043A\u0440\u043E\u0432\u044C
      \u2014 \u044D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044C
      \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438 \u0431\u044B \u043F\u0440\u0438
      \u0436\u0438\u0437\u043D\u0438. \u0421\u0438\u043C\u043F\u0442\u043E\u043C\u044B
      \u2014 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u043A\u043B\u0438\u043D\u0438\u043A\u0430 \u0445\u0440\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
      \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.\xBB"
  evidence:
  - evidenceId: e2_medical
    title: "\u041C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u043E\u0435 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435"
    baseDescription: "\u041F\u0440\u0438\u0447\u0438\u043D\u0430 \u0441\u043C\u0435\u0440\u0442\u0438
      \u2014 \u043E\u0441\u0442\u0440\u0430\u044F \u043F\u043E\u0447\u0435\u0447\u043D\u0430\u044F
      \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C.
      \u0412 \u043A\u0440\u043E\u0432\u0438 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D
      \u044D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044C.
      \u0410\u043B\u043A\u043E\u0433\u043E\u043B\u044C\u043D\u0430\u044F \u0431\u043E\u043B\u0435\u0437\u043D\u044C
      \u043F\u0435\u0447\u0435\u043D\u0438 \u0432 \u0430\u043D\u0430\u043C\u043D\u0435\u0437\u0435.
      \u0423\u0440\u043E\u0432\u0435\u043D\u044C \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u044F
      \u0432 \u043A\u0440\u043E\u0432\u0438 \u2014 1.8 \u043F\u0440\u043E\u043C\u0438\u043B\u043B\u0435."
    expertDescription: "\u041A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u044F
      \u044D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044F
      \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
      \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435 \u0432 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C
      \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 2-3
      \u043D\u0435\u0434\u0435\u043B\u044C. \u041D\u0435 \u0440\u0430\u0437\u043E\u0432\u0430\u044F
      \u0434\u043E\u0437\u0430, \u0430 \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0435
      \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u043C\u0430\u043B\u044B\u0445
      \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432. \u042D\u0442\u043E
      \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0437\u043D\u0430\u043D\u0438\u044F
      \u0434\u043E\u0437\u0438\u0440\u043E\u0432\u043A\u0438 \u0438 \u043A\u043B\u0438\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
      \u043A\u0430\u0440\u0442\u0438\u043D\u044B \u2014 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0435
      \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u043F\u0440\u0438
      \u0442\u0430\u043A\u043E\u0439 \u0441\u0445\u0435\u043C\u0435 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u043E."
  - evidenceId: e2_bottle
    title: "\u0411\u0443\u0442\u044B\u043B\u043A\u0430 \u0432\u0438\u0441\u043A\u0438"
    baseDescription: "\u041F\u043E\u0447\u0430\u0442\u0430\u044F \u0431\u0443\u0442\u044B\u043B\u043A\u0430
      \u0432\u0438\u0441\u043A\u0438 \u0438\u0437 \u0434\u043E\u043C\u0430 \u0420\u0438\u0432\u0435\u0440\u044B.
      \u041E\u0442\u043F\u0435\u0447\u0430\u0442\u043A\u0438 \u043E\u0431\u043E\u0438\u0445
      \u0441\u0443\u043F\u0440\u0443\u0433\u043E\u0432. \u0410\u043D\u0434\u0440\u0435\u0439
      \u043F\u0438\u043B \u0438\u0437 \u043D\u0435\u0451 \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E.
      \u0412\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u043E \u2014 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
      \u0432\u0438\u0441\u043A\u0438, \u0431\u0435\u0437 \u0432\u0438\u0434\u0438\u043C\u044B\u0445
      \u043F\u0440\u0438\u043C\u0435\u0441\u0435\u0439."
    expertDescription: "\u0425\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0430\u043D\u0430\u043B\u0438\u0437: \u0441\u043B\u0435\u0434\u044B \u044D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044F
      \u043D\u0430 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0445 \u0441\u0442\u0435\u043D\u043A\u0430\u0445
      \u0431\u0443\u0442\u044B\u043B\u043A\u0438 \u0438 \u043D\u0430 \u0434\u043D\u0435.
      \u041A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u044F \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
      \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u043C\u0443 \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0438\u044E
      \u2014 \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E 5-7 \u043C\u043B \u0437\u0430
      \u0440\u0430\u0437. \u042D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044C
      \u0441\u043B\u0430\u0434\u043A\u043E\u0432\u0430\u0442 \u043D\u0430 \u0432\u043A\u0443\u0441
      \u0438 \u043D\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442\u0441\u044F
      \u0432 \u043A\u0440\u0435\u043F\u043A\u043E\u043C \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0435."
  - evidenceId: e2_insurance
    title: "\u0421\u0442\u0440\u0430\u0445\u043E\u0432\u043E\u0439 \u043F\u043E\u043B\u0438\u0441"
    baseDescription: "\u041F\u043E\u043B\u0438\u0441 \u043D\u0430 $800 000 \u043D\u0430
      \u0436\u0438\u0437\u043D\u044C \u0410\u043D\u0434\u0440\u0435\u044F \u0420\u0438\u0432\u0435\u0440\u044B.
      \u0411\u0435\u043D\u0435\u0444\u0438\u0446\u0438\u0430\u0440 \u2014 \u0415\u043B\u0435\u043D\u0430.
      \u041E\u0444\u043E\u0440\u043C\u043B\u0435\u043D \u0437\u0430 \u0434\u0432\u0430
      \u043C\u0435\u0441\u044F\u0446\u0430 \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438.
      \u0421\u0442\u0440\u0430\u0445\u043E\u0432\u043E\u0439 \u0430\u0433\u0435\u043D\u0442
      \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0443\u044E
      \u043F\u0440\u043E\u0446\u0435\u0434\u0443\u0440\u0443."
    expertDescription: "\u0414\u0435\u0442\u0430\u043B\u0438 \u043E\u0444\u043E\u0440\u043C\u043B\u0435\u043D\u0438\u044F:
      \u0415\u043B\u0435\u043D\u0430 \u043B\u0438\u0447\u043D\u043E \u0437\u0432\u043E\u043D\u0438\u043B\u0430
      \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043E\u043C\u0443 \u0430\u0433\u0435\u043D\u0442\u0443
      \u0442\u0440\u0438 \u0440\u0430\u0437\u0430 \u0437\u0430 \u043D\u0435\u0434\u0435\u043B\u044E
      \u0434\u043E \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043D\u0438\u044F.
      \u0422\u043E\u0440\u043E\u043F\u0438\u043B\u0430 \u043F\u0440\u043E\u0446\u0435\u0441\u0441.
      \u041D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B\u0430 \u043D\u0430 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
      \u0441\u0443\u043C\u043C\u0435. \u0410\u0433\u0435\u043D\u0442 \u043E\u0442\u043C\u0435\u0442\u0438\u043B
      \u0432 CRM: \xAB\u043A\u043B\u0438\u0435\u043D\u0442\u043A\u0430 \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u0430,
      \u043F\u0440\u043E\u0441\u0438\u0442 \u0443\u0441\u043A\u043E\u0440\u0438\u0442\u044C\xBB.
      \u0410\u043D\u0434\u0440\u0435\u0439 \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043B
      \u043F\u043E\u043B\u0438\u0441 \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438
      \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u044C\u043D\u043E\u0433\u043E \u043E\u043F\u044C\u044F\u043D\u0435\u043D\u0438\u044F
      \u2014 \u043D\u043E\u0442\u0430\u0440\u0438\u0443\u0441 \u0437\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043B."
  testimonies:
  - witnessName: "\u041A\u043E\u0443\u043B (\u0441\u0442\u0430\u0440\u0448\u0438\u0439
      \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C)"
    baseTestimony: "\xAB\u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0435
      \u0431\u044B\u0442\u043E\u0432\u043E\u0435 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435.
      \u0416\u0435\u043D\u0430-\u043C\u0435\u0434\u0441\u0435\u0441\u0442\u0440\u0430,
      \u043D\u043E\u0432\u044B\u0439 \u043C\u0443\u0436\u0447\u0438\u043D\u0430,
      \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0430 \u043D\u0430 $800 000
      \u0437\u0430 \u0434\u0432\u0430 \u043C\u0435\u0441\u044F\u0446\u0430 \u0434\u043E
      \u0441\u043C\u0435\u0440\u0442\u0438. \u0415\u043B\u0435\u043D\u0430 \u0437\u043D\u0430\u0435\u0442
      \u0434\u043E\u0437\u0438\u0440\u043E\u0432\u043A\u0438. \u0418\u043C\u0435\u043B\u0430
      \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u0439 \u0434\u043E\u0441\u0442\u0443\u043F
      \u043A \u0431\u0443\u0442\u044B\u043B\u043A\u0435. \u041C\u043E\u0442\u0438\u0432,
      \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
      \u2014 \u0432\u0441\u0451 \u043D\u0430 \u043C\u0435\u0441\u0442\u0435.\xBB"
    clarification: "\xAB\u041F\u0440\u043E\u0432\u0435\u0440\u0438\u043B \u043A\u0430\u043C\u0435\u0440\u044B
      \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
      \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0430. \u0417\u0430 10 \u0434\u043D\u0435\u0439
      \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u0415\u043B\u0435\u043D\u0430
      \u043A\u0443\u043F\u0438\u043B\u0430 \u043A\u0430\u043D\u0438\u0441\u0442\u0440\u0443
      \u0430\u043D\u0442\u0438\u0444\u0440\u0438\u0437\u0430. \u0427\u0435\u043A
      \u043E\u043F\u043B\u0430\u0447\u0435\u043D \u043D\u0430\u043B\u0438\u0447\u043D\u044B\u043C\u0438.
      \u041D\u0430 \u043A\u0430\u043C\u0435\u0440\u0435 \u2014 \u043E\u043D\u0430.
      \u0414\u043E\u043C\u0430 \u0443\u0436\u0435 \u0431\u044B\u043B\u0430 \u043A\u0430\u043D\u0438\u0441\u0442\u0440\u0430
      \u0432 \u0433\u0430\u0440\u0430\u0436\u0435, \u043F\u043E\u043B\u043D\u0430\u044F.
      \u0417\u0430\u0447\u0435\u043C \u0432\u0442\u043E\u0440\u0430\u044F?\xBB"
  - witnessName: "\u041F\u044D\u0439\u0434\u0436 (\u044D\u043A\u0441\u043F\u0435\u0440\u0442-\u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A)"
    baseTestimony: "\xAB\u042D\u0442\u0438\u043B\u0435\u043D\u0433\u043B\u0438\u043A\u043E\u043B\u044C
      \u043C\u043E\u0433 \u043F\u043E\u043F\u0430\u0441\u0442\u044C \u0432 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C
      \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E \u2014 \u0410\u043D\u0434\u0440\u0435\u0439
      \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u0433\u0430\u0440\u0430\u0436\u0435
      \u0433\u0434\u0435 \u0445\u0440\u0430\u043D\u0438\u043B\u0441\u044F \u0430\u043D\u0442\u0438\u0444\u0440\u0438\u0437.
      \u0422\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043C\u043E\u0433
      \u0432\u044B\u043F\u0438\u0442\u044C \u043F\u043E \u043E\u0448\u0438\u0431\u043A\u0435.
      \u041D\u043E \u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u044F
      \u0432 \u043A\u0440\u043E\u0432\u0438 \u043D\u0435 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
      \u0440\u0430\u0437\u043E\u0432\u043E\u043C\u0443 \u043F\u0440\u0438\u0451\u043C\u0443.
      \u041D\u0443\u0436\u043D\u044B \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u0430\u043D\u0430\u043B\u0438\u0437\u044B.\xBB"
    clarification: "\xAB\u041F\u0435\u0440\u0435\u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B\u0430.
      \u041A\u0430\u043D\u0438\u0441\u0442\u0440\u0430 \u0430\u043D\u0442\u0438\u0444\u0440\u0438\u0437\u0430
      \u0432 \u0433\u0430\u0440\u0430\u0436\u0435 \u043D\u0435 \u0432\u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0430\u0441\u044C
      \u2014 \u0437\u0430\u0432\u043E\u0434\u0441\u043A\u0430\u044F \u043F\u043B\u043E\u043C\u0431\u0430
      \u0446\u0435\u043B\u0430. \u0410\u043D\u0442\u0438\u0444\u0440\u0438\u0437
      \u043F\u043E\u043F\u0430\u043B \u0432 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C
      \u043D\u0435 \u0438\u0437 \u0433\u0430\u0440\u0430\u0436\u0430. \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u0434\u0440\u0443\u0433\u043E\u0439 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A
      \u0432 \u0434\u043E\u043C\u0435 \u2014 \u0432\u0442\u043E\u0440\u0430\u044F
      \u043A\u0430\u043D\u0438\u0441\u0442\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
      \u0415\u043B\u0435\u043D\u0430 \u043A\u0443\u043F\u0438\u043B\u0430. \u041E\u043D\u0430
      \u043D\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0430.\xBB"
  - witnessName: "\u041D\u044D\u0448 (\u043F\u043E\u043B\u0435\u0432\u043E\u0439
      \u0430\u0433\u0435\u043D\u0442)"
    baseTestimony: "\xAB\u0412\u0438\u043A\u0442\u043E\u0440\u0438\u044F \u0420\u0438\u0432\u0435\u0440\u0430
      \u043F\u043E\u0434\u0430\u043B\u0430 \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435
      \u043D\u0430 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E \u0447\u0435\u0440\u0435\u0437
      \u0447\u0430\u0441 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
      \u043E\u0442\u0446\u0430. \u0423 \u043D\u0435\u0451 \u0442\u043E\u0436\u0435
      \u043C\u043E\u0442\u0438\u0432 \u2014 \u0435\u0441\u043B\u0438 \u0415\u043B\u0435\u043D\u0430
      \u043E\u0441\u0443\u0436\u0434\u0435\u043D\u0430, \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0430
      \u043D\u0435 \u0432\u044B\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E \u0434\u0435\u043B\u0438\u0442\u0441\u044F
      \u043F\u043E \u0437\u0430\u043A\u043E\u043D\u0443. \u0412\u0438\u043A\u0442\u043E\u0440\u0438\u044F
      \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043D\u0430
      \u0432 \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u0438.\xBB"
    clarification: "\xAB\u041F\u0440\u043E\u0432\u0435\u0440\u0438\u043B \u0437\u0432\u043E\u043D\u043A\u0438
      \u0415\u043B\u0435\u043D\u044B. \u0417\u0430 \u0434\u0435\u043D\u044C \u0434\u043E
      \u0441\u043C\u0435\u0440\u0442\u0438 \u0410\u043D\u0434\u0440\u0435\u044F \u2014
      \u0437\u0432\u043E\u043D\u043E\u043A \u041E\u0440\u043B\u043E\u0432\u0443,
      23 \u043C\u0438\u043D\u0443\u0442\u044B. \u041E\u0440\u043B\u043E\u0432 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
      \u2014 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B\u0438 \u0440\u0430\u0437\u0432\u043E\u0434.
      \u041D\u043E \u0432 \u0442\u043E\u0442 \u0436\u0435 \u0432\u0435\u0447\u0435\u0440
      \u0415\u043B\u0435\u043D\u0430 \u0433\u0443\u0433\u043B\u0438\u043B\u0430 '\u0447\u0435\u0440\u0435\u0437
      \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u044B\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043A\u0430 \u043F\u043E\u0441\u043B\u0435
