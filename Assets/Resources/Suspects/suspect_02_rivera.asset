    answer: "\xAB\u041D\u0435\u0442. \u042F \u0434\u0430\u0436\u0435 \u043D\u0435
      \u043F\u0440\u0438\u043A\u0430\u0441\u0430\u043B\u0430\u0441\u044C \u043A \u0435\u0433\u043E
      \u0431\u0443\u0442\u044B\u043B\u043A\u0430\u043C. \u0410\u043D\u0434\u0440\u0435\u0439
      \u043F\u0438\u043B \u0441\u0430\u043C \u2014 \u043A\u0430\u0436\u0434\u044B\u0439
