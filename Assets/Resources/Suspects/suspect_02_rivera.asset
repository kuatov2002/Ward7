    text: "\u0423 \u041C\u0430\u0440\u0438\u043D\u044B \u043D\u0435\u0442 \u043C\u0430\u0448\u0438\u043D\u044B
      \u2014 \u0430\u043B\u0438\u0431\u0438 \u0415\u043B\u0435\u043D\u044B \u043D\u0435
      \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442"
    supportsGuilty: 1
    weight: 2
  consequenceGuilty: 
  consequenceNotGuilty: "\u0415\u043B\u0435\u043D\u0430 \u0420\u0438\u0432\u0435\u0440\u0430
    \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0430. \u0427\u0435\u0440\u0435\u0437
    \u0442\u0440\u0438 \u043C\u0435\u0441\u044F\u0446\u0430 \u2014 \u0414\u043C\u0438\u0442\u0440\u0438\u0439
    \u041E\u0440\u043B\u043E\u0432 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D
    \u043C\u0451\u0440\u0442\u0432\u044B\u043C \u0432 \u0441\u0432\u043E\u0435\u0439
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435. \u041F\u0440\u0438\u0447\u0438\u043D\u0430
    \u0441\u043C\u0435\u0440\u0442\u0438 \u2014 \u043F\u043E\u0447\u0435\u0447\u043D\u0430\u044F
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C.
    \u041F\u043E\u0432\u0442\u043E\u0440\u043D\u0430\u044F \u044D\u043A\u0441\u043F\u0435\u0440\u0442\u0438\u0437\u0430
    \u0442\u0435\u043B\u0430 \u0410\u043D\u0434\u0440\u0435\u044F \u0420\u0438\u0432\u0435\u0440\u044B
    \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0430. \u0414\u0435\u043B\u043E
    \u0432\u043E\u0437\u043E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u043E."
