  followUps:
  - followUpId: fu3_why
    question: "\u0417\u0430\u0447\u0435\u043C \u0417\u043E\u0442\u043E\u0432\u0443
      \u0432\u0430\u0441 \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0442\u044C?
      \u0427\u0442\u043E \u043E\u043D \u0432\u044B\u0438\u0433\u0440\u044B\u0432\u0430\u0435\u0442?"
    answer: "\xAB\u041A\u043E\u0437\u043B\u0430 \u043E\u0442\u043F\u0443\u0449\u0435\u043D\u0438\u044F.
      \u0415\u0441\u043B\u0438 \u0443\u0442\u0435\u0447\u043A\u0443 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0430\u0442
