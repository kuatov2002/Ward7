    \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043D \u043F\u0440\u0438 \u043F\u043E\u043F\u044B\u0442\u043A\u0435
    \u043F\u0440\u043E\u0434\u0430\u0442\u044C \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E
    \u043F\u0430\u0440\u0442\u0438\u044E \u0434\u0430\u043D\u043D\u044B\u0445. \u0411\u0435\u043B\u043E\u0432
