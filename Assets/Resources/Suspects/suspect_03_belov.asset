      \u0417\u043E\u0442\u043E\u0432\u0430. \u0412\u0430\u0448 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439?"
    answer: "(\u041E\u0431\u043B\u0435\u0433\u0447\u0435\u043D\u0438\u0435 \u043D\u0430
      \u043B\u0438\u0446\u0435.) \xAB\u0412\u043E\u0442. \u0412\u043E\u0442 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E.
      \u042D\u0442\u043E \u043D\u0435 \u043C\u043E\u0439 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440.
      \u0417\u043E\u0442\u043E\u0432 \u0432\u043E\u0448\u0451\u043B \u043F\u043E\u0434
      \u043C\u043E\u0438\u043C \u043B\u043E\u0433\u0438\u043D\u043E\u043C \u0441\u043E
      \u0441\u0432\u043E\u0435\u0439 \u043C\u0430\u0448\u0438\u043D\u044B. \u041E\u043D
      \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440
      \u2014 \u043E\u043D \u043C\u043E\u0436\u0435\u0442 \u0441\u0431\u0440\u043E\u0441\u0438\u0442\u044C
      \u043C\u043E\u0439 \u043F\u0430\u0440\u043E\u043B\u044C \u0437\u0430 \u0441\u0435\u043A\u0443\u043D\u0434\u0443.\xBB"
    pressureChange: 0
  - requiredChoiceType: 1
    requiredChoiceId: e3_usb
    question: "\u0424\u0430\u0439\u043B\u044B \u043D\u0430 \u0444\u043B\u0435\u0448\u043A\u0435
      \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u044B \u0432 02:15. \u041A\u0430\u043C\u0435\u0440\u0430
      \u043F\u0430\u0440\u043A\u043E\u0432\u043A\u0438 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
      \u2014 \u0432\u0430\u0441 \u043D\u0435 \u0431\u044B\u043B\u043E \u0432 \u0437\u0434\u0430\u043D\u0438\u0438.
      \u041D\u043E \u0444\u043B\u0435\u0448\u043A\u0430 \u0432 \u0432\u0430\u0448\u0435\u043C
      \u0441\u0442\u043E\u043B\u0435."
    answer: "\xAB\u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043A\u0442\u043E-\u0442\u043E
      \u043F\u043E\u043B\u043E\u0436\u0438\u043B \u0435\u0451 \u0442\u0443\u0434\u0430.
      \u0417\u043E\u0442\u043E\u0432 \u0431\u044B\u043B \u0432 \u0437\u0434\u0430\u043D\u0438\u0438
      \u0434\u043E \u0442\u0440\u0451\u0445 \u043D\u043E\u0447\u0438 \u2014 \u043A\u0430\u043C\u0435\u0440\u0430
      \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442. \u0423
      \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u043E \u0432\u0440\u0435\u043C\u044F
      \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u0444\u0430\u0439\u043B\u044B
      \u0438 \u043F\u043E\u0434\u0431\u0440\u043E\u0441\u0438\u0442\u044C \u0444\u043B\u0435\u0448\u043A\u0443.
      \u042F\u0449\u0438\u043A\u0438 \u043D\u0435 \u0437\u0430\u043F\u0438\u0440\u0430\u044E\u0442\u0441\u044F.\xBB"
    pressureChange: 0
  - requiredChoiceType: 1
    requiredChoiceId: e3_emails
    question: "\u041B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0430\u043D\u0430\u043B\u0438\u0437 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438
      \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0430 \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u043B\u043E\u0433\u0438\u044E
      \u0417\u043E\u0442\u043E\u0432\u0430, \u043D\u0435 \u0432\u0430\u0448\u0443.
      \u0412\u044B \u043A\u043E\u0433\u0434\u0430-\u043D\u0438\u0431\u0443\u0434\u044C
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438 \u0442\u0435\u0440\u043C\u0438\u043D
      \xAB\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F \u043A\u043B\u0430\u0441\u0442\u0435\u0440\u043E\u0432\xBB?"
    answer: "\xAB\u041D\u0435\u0442. \u042D\u0442\u043E \u043D\u0435 \u043C\u043E\u0439
      \u0442\u0435\u0440\u043C\u0438\u043D. \u0417\u043E\u0442\u043E\u0432 \u0442\u0430\u043A
      \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0432 \u043A\u0430\u0436\u0434\u043E\u043C
      \u043E\u0442\u0447\u0451\u0442\u0435. \u042F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E
      '\u043F\u0435\u0440\u0435\u043D\u043E\u0441 \u0434\u0430\u043D\u043D\u044B\u0445'.
      \u0421\u043F\u0440\u043E\u0441\u0438\u0442\u0435 \u043B\u044E\u0431\u043E\u0433\u043E
      \u0432 \u043E\u0442\u0434\u0435\u043B\u0435 \u2014 \u044D\u0442\u043E \u0435\u0433\u043E
      \u0441\u043B\u043E\u0432\u0435\u0447\u043A\u043E.\xBB"
    pressureChange: 0
  - requiredChoiceType: 2
    requiredChoiceId: "\u041A\u043E\u0443\u043B (\u0441\u0442\u0430\u0440\u0448\u0438\u0439
      \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C)"
    question: "\u041A\u043E\u0443\u043B \u043D\u0435 \u043D\u0430\u0448\u0451\u043B
      \u0443 \u0432\u0430\u0441 \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
      \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439. \u0415\u0441\u043B\u0438
      \u0432\u044B \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B\u0438 \u0434\u0430\u043D\u043D\u044B\u0435
      \u2014 \u0433\u0434\u0435 \u0434\u0435\u043D\u044C\u0433\u0438?"
    answer: "\xAB\u041D\u0435\u0442 \u0434\u0435\u043D\u0435\u0433 \u043F\u043E\u0442\u043E\u043C\u0443
      \u0447\u0442\u043E \u044F \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
      \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B. \u041F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435
      \u0417\u043E\u0442\u043E\u0432\u0430 \u2014 \u0435\u0433\u043E \u043A\u0440\u0435\u0434\u0438\u0442
      \u043D\u0430 $50 000 '\u043D\u0430 \u0440\u0435\u043C\u043E\u043D\u0442' \u0432
      \u0441\u044A\u0451\u043C\u043D\u043E\u0439 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435.
      \u0412\u043E\u0442 \u0433\u0434\u0435 \u0434\u0435\u043D\u044C\u0433\u0438.\xBB"
    pressureChange: 0
  - requiredChoiceType: 2
    requiredChoiceId: "\u041F\u044D\u0439\u0434\u0436 (\u044D\u043A\u0441\u043F\u0435\u0440\u0442-\u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A)"
    question: "\u041F\u044D\u0439\u0434\u0436 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442
      \u2014 MAC-\u0430\u0434\u0440\u0435\u0441 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
      \u0417\u043E\u0442\u043E\u0432\u0443. \u041E\u043D \u043C\u043E\u0433 \u0432\u043E\u0439\u0442\u0438
      \u043F\u043E\u0434 \u0432\u0430\u0448\u0438\u043C \u043B\u043E\u0433\u0438\u043D\u043E\u043C?"
    answer: "\xAB\u041A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u043E\u0433. \u041E\u043D
      \u2014 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440.
      \u0421\u0431\u0440\u043E\u0441 \u043F\u0430\u0440\u043E\u043B\u044F, \u0432\u0445\u043E\u0434
      \u043F\u043E\u0434 \u043B\u044E\u0431\u043E\u0439 \u0443\u0447\u0451\u0442\u043A\u043E\u0439
      \u2014 \u044D\u0442\u043E \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0447\u0438\u0435
      \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B. \u0414\u043B\u044F
      \u044D\u0442\u043E\u0433\u043E \u0434\u0430\u0436\u0435 \u043D\u0435 \u043D\u0443\u0436\u043D\u043E
      \u0432\u0437\u043B\u0430\u043C\u044B\u0432\u0430\u0442\u044C \u2014 \u043F\u0440\u043E\u0441\u0442\u043E
      \u043D\u0430\u0436\u0430\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0443 \u0432
      \u043F\u0430\u043D\u0435\u043B\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.\xBB"
    pressureChange: 0
  - requiredChoiceType: 2
    requiredChoiceId: "\u041D\u044D\u0448 (\u043F\u043E\u043B\u0435\u0432\u043E\u0439
      \u0430\u0433\u0435\u043D\u0442)"
    question: "\u0417\u043E\u0442\u043E\u0432 \u0432\u0437\u044F\u043B \u043A\u0440\u0435\u0434\u0438\u0442
      $50 000 \u043D\u0430 \u0440\u0435\u043C\u043E\u043D\u0442 \u2014 \u043D\u043E
      \u0436\u0438\u0432\u0451\u0442 \u0432 \u0441\u044A\u0451\u043C\u043D\u043E\u0439
      \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435. \u0414\u0435\u043D\u044C\u0433\u0438
      \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0435\u043D\u044B. \u0412\u044B
      \u0437\u043D\u0430\u043B\u0438 \u043E\u0431 \u044D\u0442\u043E\u043C?"
    answer: "\xAB\u041D\u0435\u0442. \u041D\u043E \u044D\u0442\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442
      \u0432\u0441\u0451. \u0417\u043E\u0442\u043E\u0432 \u043F\u0440\u043E\u0434\u0430\u043B
      \u0434\u0430\u043D\u043D\u044B\u0435, \u043F\u043E\u043B\u0443\u0447\u0438\u043B
      \u0430\u0432\u0430\u043D\u0441, \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0438\u043B
      \u0447\u0435\u0440\u0435\u0437 \u043A\u0440\u0435\u0434\u0438\u0442 \u0447\u0442\u043E\u0431\u044B
      \u043D\u0435 \u0441\u0432\u0435\u0442\u0438\u0442\u044C \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A.
      \u0410 \u043C\u0435\u043D\u044F \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u0438\u043B
      \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0432\u0435\u0441\u0442\u0438 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u044F.\xBB"
    pressureChange: 0
  bluffQuestions:
  - question: "\u041C\u044B \u043E\u0442\u0441\u043B\u0435\u0434\u0438\u043B\u0438
