      \u0432\u0430\u0448\u0443 \u043D\u0435\u0432\u0438\u043D\u043E\u0432\u043D\u043E\u0441\u0442\u044C?"
    answer: "(\u0414\u043E\u0441\u0442\u0430\u0451\u0442 \u0442\u0435\u043B\u0435\u0444\u043E\u043D.)
      \xAB\u0421\u043A\u0440\u0438\u043D\u0448\u043E\u0442\u044B \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0439
      \u043E\u0442 \u0417\u043E\u0442\u043E\u0432\u0430. \u041A\u0430\u0436\u0434\u044B\u0439
      \u0432\u0435\u0447\u0435\u0440 \u2014 '\u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0441\u044C,
      \u043D\u0443\u0436\u043D\u043E \u0434\u043E\u0434\u0435\u043B\u0430\u0442\u044C
      \u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044E'. \u041A\u0430\u0436\u0434\u044B\u0439
      \u0440\u0430\u0437 \u2014 \u0437\u0430\u0434\u0430\u043D\u0438\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0435
      \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u043C\u043E\u0439 \u043B\u043E\u0433\u0438\u043D
      \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0435. \u041E\u043D \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B
      \u044D\u0442\u043E \u043D\u0435\u0434\u0435\u043B\u044F\u043C\u0438.\xBB"
  - followUpId: fu3_family
    question: "\u0415\u0441\u043B\u0438 \u0432\u0430\u0441 \u043E\u0441\u0443\u0434\u044F\u0442
      \u2014 \u0447\u0442\u043E \u0431\u0443\u0434\u0435\u0442 \u0441 \u0441\u0435\u043C\u044C\u0451\u0439?"
    answer: "(\u0414\u043E\u043B\u0433\u043E\u0435 \u043C\u043E\u043B\u0447\u0430\u043D\u0438\u0435.)
      \xAB\u041E\u043B\u044C\u0433\u0430 \u043E\u0434\u043D\u0430 \u0441 \u0440\u0435\u0431\u0451\u043D\u043A\u043E\u043C.
      \u0418\u043F\u043E\u0442\u0435\u043A\u0430. \u0427\u0435\u0442\u044B\u0440\u0435
      \u0433\u043E\u0434\u0430 \u0441\u044B\u043D\u0443.\xBB (\u0413\u043E\u043B\u043E\u0441
      \u043B\u043E\u043C\u0430\u0435\u0442\u0441\u044F.) \xAB\u042F \u043D\u0435
      \u0432\u043E\u0440\u043E\u0432\u0430\u043B \u044D\u0442\u0438 \u0434\u0430\u043D\u043D\u044B\u0435.
      \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430. \u041F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435
      \u0417\u043E\u0442\u043E\u0432\u0430.\xBB"
  pressureThreshold: 4
  arguments:
  - argumentId: arg_1
    text: "\u0414\u043E\u0441\u0442\u0443\u043F \u043A \u0431\u0430\u0437\u0435 \u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043B\u0451\u043D
