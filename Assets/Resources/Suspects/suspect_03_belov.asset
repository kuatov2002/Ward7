  displayName: "\u0410\u0440\u0442\u0451\u043C \u0411\u0435\u043B\u043E\u0432"
  weekNumber: 3
  isGuilty: 0
  dossierText: "\u0410\u0440\u0442\u0451\u043C \u0411\u0435\u043B\u043E\u0432, 29
    \u043B\u0435\u0442. \u041E\u0431\u0432\u0438\u043D\u044F\u0435\u0442\u0441\u044F
    \u0432 \u043A\u0440\u0430\u0436\u0435 \u043A\u043E\u043D\u0444\u0438\u0434\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445 12 000 \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432
    \u0438\u0437 \u043A\u043B\u0438\u043D\u0438\u043A\u0438 \xAB\u041C\u0435\u0434\u041B\u0430\u0439\u043D\xBB
    \u0438 \u043F\u043E\u043F\u044B\u0442\u043A\u0435 \u043F\u0440\u043E\u0434\u0430\u0436\u0438
    \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u043E\u0439 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438
    \xAB\u0413\u0430\u0440\u0430\u043D\u0442-\u041F\u043B\u044E\u0441\xBB.\r\n\r\n\u0411\u0435\u043B\u043E\u0432
    \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u044B\u0439 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440
    \xAB\u041C\u0435\u0434\u041B\u0430\u0439\u043D\xBB, \u0441\u0442\u0430\u0436
    3 \u0433\u043E\u0434\u0430. \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0430
    \u043E\u0442 HR \u2014 \xAB\u043A\u043E\u043C\u043F\u0435\u0442\u0435\u043D\u0442\u043D\u044B\u0439,
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0439, \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432
    \u043D\u0435 \u0437\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u043E\xBB.
    \u0417\u0430\u0440\u043F\u043B\u0430\u0442\u0430 \u2014 \u043D\u0438\u0436\u0435
    \u0440\u044B\u043D\u043E\u0447\u043D\u043E\u0439. \u0414\u0432\u0430\u0436\u0434\u044B
    \u043F\u0440\u043E\u0441\u0438\u043B \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u0435
    \u2014 \u043E\u0431\u0430 \u0440\u0430\u0437\u0430 \u043E\u0442\u043A\u0430\u0437.\r\n\r\n\u041D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A
    IT-\u043E\u0442\u0434\u0435\u043B\u0430 \u2014 \u0418\u0433\u043E\u0440\u044C
    \u0417\u043E\u0442\u043E\u0432 (41 \u0433\u043E\u0434). \u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B
    \u0443\u0442\u0435\u0447\u043A\u0443 \u0438 \u0441\u043E\u043E\u0431\u0449\u0438\u043B
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u0443. \u0418\u043C\u0435\u043D\u043D\u043E
    \u043F\u043E \u0435\u0433\u043E \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u044E
    \u0432\u043E\u0437\u0431\u0443\u0436\u0434\u0435\u043D\u043E \u0434\u0435\u043B\u043E.\r\n\r\n\u0421\u0435\u0440\u0432\u0435\u0440\u043D\u044B\u0435
    \u043B\u043E\u0433\u0438 \u0444\u0438\u043A\u0441\u0438\u0440\u0443\u044E\u0442
    \u0432\u0445\u043E\u0434 \u0432 \u0431\u0430\u0437\u0443 \u0434\u0430\u043D\u043D\u044B\u0445
    \u0441 \u0443\u0447\u0451\u0442\u043D\u043E\u0439 \u0437\u0430\u043F\u0438\u0441\u0438
    \u0411\u0435\u043B\u043E\u0432\u0430 \u0432 23:47. \u0421\u043A\u0430\u0447\u0430\u043D\u043E
    12 000 \u0437\u0430\u043F\u0438\u0441\u0435\u0439 \u0437\u0430 15 \u043C\u0438\u043D\u0443\u0442.
    \u0412 \u044F\u0449\u0438\u043A\u0435 \u0441\u0442\u043E\u043B\u0430 \u0411\u0435\u043B\u043E\u0432\u0430
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D USB-\u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0435\u043B\u044C
    \u0441 \u043A\u043E\u043F\u0438\u0435\u0439 \u0431\u0430\u0437\u044B.\r\n\r\n\u0421
    \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0433\u043E email-\u0430\u043A\u043A\u0430\u0443\u043D\u0442\u0430
    \u0432\u0435\u043B\u0430\u0441\u044C \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430
    \u0441 \xAB\u0413\u0430\u0440\u0430\u043D\u0442-\u041F\u043B\u044E\u0441\xBB
    \u043E \u043F\u0440\u043E\u0434\u0430\u0436\u0435 \u0434\u0430\u043D\u043D\u044B\u0445.
    \u041A\u043E\u043C\u043F\u0430\u043D\u0438\u044F \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u0438 \u0441\u043E\u043E\u0431\u0449\u0438\u043B\u0430 \u0432 \u043F\u043E\u043B\u0438\u0446\u0438\u044E.\r\n\r\n\u0411\u0435\u043B\u043E\u0432
    \u043E\u0442\u0440\u0438\u0446\u0430\u0435\u0442 \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u044C.
    \u0423\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442 \u0447\u0442\u043E
    \u043A\u0442\u043E-\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0443\u0447\u0451\u0442\u043D\u0443\u044E \u0437\u0430\u043F\u0438\u0441\u044C.\r\n\r\n\u0416\u0435\u043D\u0430
    \u2014 \u041E\u043B\u044C\u0433\u0430, \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440.
    \u0420\u0435\u0431\u0451\u043D\u043E\u043A \u2014 4 \u0433\u043E\u0434\u0430.
    \u0418\u043F\u043E\u0442\u0435\u043A\u0430."
  contacts:
  - contactId: c3_zotov
    displayName: "\u0418\u0433\u043E\u0440\u044C \u0417\u043E\u0442\u043E\u0432 (\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A
      IT)"
    response: "\xAB\u0411\u0435\u043B\u043E\u0432 \u0432\u0441\u0435\u0433\u0434\u0430
      \u0431\u044B\u043B \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u0435\u043D \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u043E\u0439.
      \u0413\u043E\u0432\u043E\u0440\u0438\u043B \u0447\u0442\u043E \u0435\u0433\u043E
      \u043D\u0435 \u0446\u0435\u043D\u044F\u0442. \u042F \u0441\u0430\u043C \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B
      \u0443\u0442\u0435\u0447\u043A\u0443 \u2014 \u043B\u043E\u0433-\u043C\u043E\u043D\u0438\u0442\u043E\u0440\u0438\u043D\u0433
      \u043F\u043E\u043A\u0430\u0437\u0430\u043B \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u044B\u0439
      \u043E\u0431\u044A\u0451\u043C \u0434\u0430\u043D\u043D\u044B\u0445. \u0421\u0440\u0430\u0437\u0443
      \u0434\u043E\u043B\u043E\u0436\u0438\u043B \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0443.
      \u041C\u043D\u0435 \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u043E \u2014
      \u0411\u0435\u043B\u043E\u0432 \u0445\u043E\u0440\u043E\u0448\u0438\u0439 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442.
      \u041D\u043E \u0444\u0430\u043A\u0442\u044B \u0435\u0441\u0442\u044C \u0444\u0430\u043A\u0442\u044B.\xBB"
  - contactId: c3_nina
    displayName: "\u041D\u0438\u043D\u0430 \u041F\u0430\u0432\u043B\u043E\u0432\u0430
      (\u043A\u043E\u043B\u043B\u0435\u0433\u0430)"
    response: "\xAB\u0410\u0440\u0442\u0451\u043C \u2014 \u0447\u0435\u0441\u0442\u043D\u044B\u0439
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u041D\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
      \u043C\u0435\u0441\u044F\u0446 \u043E\u043D \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
      \u0434\u043E\u043F\u043E\u0437\u0434\u043D\u0430. \u0417\u043E\u0442\u043E\u0432
      \u0434\u0430\u0432\u0430\u043B \u0435\u043C\u0443 \u043A\u0430\u043A\u0438\u0435-\u0442\u043E
      \u0437\u0430\u0434\u0430\u043D\u0438\u044F \u043F\u043E\u0441\u043B\u0435 \u0440\u0430\u0431\u043E\u0447\u0435\u0433\u043E
      \u0434\u043D\u044F \u2014 \u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F
      \u0441\u0435\u0440\u0432\u0435\u0440\u043E\u0432 \u0438\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E
      \u0442\u0430\u043A\u043E\u0435. \u0410\u0440\u0442\u0451\u043C \u0433\u043E\u0432\u043E\u0440\u0438\u043B
      \u0447\u0442\u043E \u0443\u0441\u0442\u0430\u043B \u0438 \u0447\u0442\u043E
      \u0417\u043E\u0442\u043E\u0432 \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F
      \u0441\u0442\u0440\u0430\u043D\u043D\u043E. \u041F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435
      \u043D\u0435 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B.\xBB"
  - contactId: c3_garant
    displayName: "\u041C\u0430\u043A\u0441\u0438\u043C \u0427\u0435\u0440\u043D\u044B\u0445
      (\u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440 \xAB\u0413\u0430\u0440\u0430\u043D\u0442-\u041F\u043B\u044E\u0441\xBB)"
    response: "\xAB\u041D\u0430\u043C \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438
      \u0434\u0430\u043D\u043D\u044B\u0435 \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E.
      \u0417\u0430\u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
      \u043F\u043E\u0447\u0442\u0430, \u043E\u043F\u043B\u0430\u0442\u0430 \u0432
      \u043A\u0440\u0438\u043F\u0442\u043E\u0432\u0430\u043B\u044E\u0442\u0435. \u041C\u044B
      \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C \u0438 \u0441\u043E\u043E\u0431\u0449\u0438\u043B\u0438
      \u0432 \u043F\u043E\u043B\u0438\u0446\u0438\u044E. \u041F\u0440\u043E\u0434\u0430\u0432\u0435\u0446
      \u0431\u044B\u043B \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D \u2014
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B VPN, \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u044B\u0439
      \u044F\u0449\u0438\u043A. \u041D\u0435 \u043F\u043E\u0445\u043E\u0436\u0435
      \u043D\u0430 \u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0435\u0448\u0438\u043B \u043F\u043E\u0434\u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C.\xBB"
  - contactId: c3_olga
    displayName: "\u041E\u043B\u044C\u0433\u0430 \u0411\u0435\u043B\u043E\u0432\u0430
      (\u0436\u0435\u043D\u0430)"
    response: "\xAB\u0410\u0440\u0442\u0451\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
      \u043C\u0435\u0441\u044F\u0446 \u043D\u0435 \u0441\u043F\u0430\u043B. \u0413\u043E\u0432\u043E\u0440\u0438\u043B
      \u0447\u0442\u043E \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0435 \u0447\u0442\u043E-\u0442\u043E
      \u043D\u0435 \u0442\u0430\u043A \u2014 \u0447\u0442\u043E \u0417\u043E\u0442\u043E\u0432
      \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F \u0441\u0442\u0440\u0430\u043D\u043D\u043E,
      \u0434\u0430\u0451\u0442 \u0437\u0430\u0434\u0430\u043D\u0438\u044F \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u043D\u0435 \u0441\u0432\u044F\u0437\u0430\u043D\u044B \u0441 \u0435\u0433\u043E
      \u0440\u0430\u0431\u043E\u0442\u043E\u0439. \u0425\u043E\u0442\u0435\u043B
      \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u0436\u0430\u043B\u043E\u0431\u0443
      \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0443. \u041D\u0435 \u0443\u0441\u043F\u0435\u043B.\xBB"
  evidence:
  - evidenceId: e3_serverlogs
    title: "\u0421\u0435\u0440\u0432\u0435\u0440\u043D\u044B\u0435 \u043B\u043E\u0433\u0438"
    baseDescription: "\u0412\u0445\u043E\u0434 \u0432 \u0431\u0430\u0437\u0443 \u0434\u0430\u043D\u043D\u044B\u0445
      \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432 \u0441 \u0443\u0447\u0451\u0442\u043D\u043E\u0439
      \u0437\u0430\u043F\u0438\u0441\u0438 user_belov \u0432 23:47. \u0421\u043A\u0430\u0447\u0430\u043D\u043E
      12 000 \u0437\u0430\u043F\u0438\u0441\u0435\u0439 \u0437\u0430 15 \u043C\u0438\u043D\u0443\u0442.
      IP-\u0430\u0434\u0440\u0435\u0441 \u2014 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0439
      VPN \u043A\u043B\u0438\u043D\u0438\u043A\u0438. \u0421\u0435\u0441\u0441\u0438\u044F
      \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0430 \u0432 00:02."
    expertDescription: "MAC-\u0430\u0434\u0440\u0435\u0441 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430
      \u0432 \u043B\u043E\u0433\u0430\u0445 \u043D\u0435 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
      \u043D\u0438 \u0441 \u043E\u0434\u043D\u0438\u043C \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C
      \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0411\u0435\u043B\u043E\u0432\u0430
      (\u043D\u043E\u0443\u0442\u0431\u0443\u043A, \u0440\u0430\u0431\u043E\u0447\u0430\u044F
      \u0441\u0442\u0430\u043D\u0446\u0438\u044F). MAC \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
      \u0441 \u0440\u0430\u0431\u043E\u0447\u0435\u0439 \u0441\u0442\u0430\u043D\u0446\u0438\u0435\u0439
      \u0417\u043E\u0442\u043E\u0432\u0430 \u2014 \u0441\u0435\u0440\u0438\u0439\u043D\u044B\u0439
      \u043D\u043E\u043C\u0435\u0440 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0451\u043D.
      \u041A\u0442\u043E-\u0442\u043E \u0432\u043E\u0448\u0451\u043B \u043F\u043E\u0434
      \u0443\u0447\u0451\u0442\u043D\u043E\u0439 \u0437\u0430\u043F\u0438\u0441\u044C\u044E
      \u0411\u0435\u043B\u043E\u0432\u0430 \u0441 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430
      \u0417\u043E\u0442\u043E\u0432\u0430."
  - evidenceId: e3_usb
    title: "USB-\u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0435\u043B\u044C"
    baseDescription: "\u0427\u0451\u0440\u043D\u044B\u0439 USB-\u043D\u0430\u043A\u043E\u043F\u0438\u0442\u0435\u043B\u044C
      \u0431\u0435\u0437 \u043C\u0430\u0440\u043A\u0438\u0440\u043E\u0432\u043A\u0438,
      \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D \u0432 \u0432\u0435\u0440\u0445\u043D\u0435\u043C
      \u044F\u0449\u0438\u043A\u0435 \u0441\u0442\u043E\u043B\u0430 \u0411\u0435\u043B\u043E\u0432\u0430.
      \u0421\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u043F\u043E\u043B\u043D\u0443\u044E
      \u043A\u043E\u043F\u0438\u044E \u0431\u0430\u0437\u044B \u0434\u0430\u043D\u043D\u044B\u0445
      \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432. \u0414\u0430\u0442\u0430
      \u0437\u0430\u043F\u0438\u0441\u0438 \u0444\u0430\u0439\u043B\u043E\u0432 \u2014
      02:15 \u043D\u043E\u0447\u0438."
    expertDescription: "\u0424\u0430\u0439\u043B\u044B \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u044B
      \u0432 02:15. \u041A\u0430\u043C\u0435\u0440\u0430 \u043F\u0430\u0440\u043A\u043E\u0432\u043A\u0438
      \u043A\u043B\u0438\u043D\u0438\u043A\u0438 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442:
      \u043C\u0430\u0448\u0438\u043D\u0430 \u0411\u0435\u043B\u043E\u0432\u0430 \u043F\u043E\u043A\u0438\u043D\u0443\u043B\u0430
      \u043F\u0430\u0440\u043A\u043E\u0432\u043A\u0443 \u0432 22:30. \u0417\u043E\u0442\u043E\u0432
      \u0432\u044B\u0448\u0435\u043B \u0438\u0437 \u0437\u0434\u0430\u043D\u0438\u044F
      \u0432 03:00. \u0411\u0435\u043B\u043E\u0432 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438
      \u043D\u0435 \u043C\u043E\u0433 \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C
      \u0444\u0430\u0439\u043B\u044B \u0432 02:15 \u2014 \u0435\u0433\u043E \u043D\u0435
      \u0431\u044B\u043B\u043E \u0432 \u0437\u0434\u0430\u043D\u0438\u0438."
  - evidenceId: e3_emails
    title: "\u041F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u0441 \xAB\u0413\u0430\u0440\u0430\u043D\u0442-\u041F\u043B\u044E\u0441\xBB"
    baseDescription: "\u0410\u043D\u043E\u043D\u0438\u043C\u043D\u0430\u044F \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430
      \u043E \u043F\u0440\u043E\u0434\u0430\u0436\u0435 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0445
      \u0434\u0430\u043D\u043D\u044B\u0445. \u0421\u0442\u0438\u043B\u044C \u2014
      \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439, \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439.
      \u0410\u0432\u0442\u043E\u0440 \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0435\u0442\u0441\u044F
      \u0432 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435 \u0431\u0430\u0437\u044B
      \u0434\u0430\u043D\u043D\u044B\u0445 \u0438 \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438
      \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0445 \u0437\u0430\u043F\u0438\u0441\u0435\u0439
      \u0434\u043B\u044F \u0441\u0442\u0440\u0430\u0445\u043E\u0432\u044B\u0445 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0439."
    expertDescription: "\u041B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0430\u043D\u0430\u043B\u0438\u0437: \u0430\u0432\u0442\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0442\u0435\u0440\u043C\u0438\u043D\u044B \u0438\u0437 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0445
      \u043E\u0442\u0447\u0451\u0442\u043E\u0432 IT-\u043E\u0442\u0434\u0435\u043B\u0430
      \u2014 \xAB\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F \u043A\u043B\u0430\u0441\u0442\u0435\u0440\u043E\u0432\xBB,
      \xAB\u0438\u043D\u0434\u0435\u043A\u0441\u0430\u0446\u0438\u044F \u043F\u043E
      ICD-10\xBB. \u0411\u0435\u043B\u043E\u0432 \u0432 \u0441\u0432\u043E\u0435\u0439
      \u0440\u0430\u0431\u043E\u0447\u0435\u0439 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435
      \u044D\u0442\u0438\u0445 \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u0432 \u043D\u0435
      \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442 \u2014 \u044D\u0442\u043E
      \u043B\u0435\u043A\u0441\u0438\u043A\u043E\u043D \u0417\u043E\u0442\u043E\u0432\u0430.
      \u041C\u0435\u0442\u0430\u0434\u0430\u043D\u043D\u044B\u0435 \u043F\u0438\u0441\u0435\u043C
      \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u043D\u0430 \u0431\u0440\u0430\u0443\u0437\u0435\u0440
      Firefox 118 \u043F\u043E\u0434 Linux \u2014 \u0411\u0435\u043B\u043E\u0432
      \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043D\u0430 Windows, \u0417\u043E\u0442\u043E\u0432
      \u2014 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C Linux
      \u0432 \u043E\u0442\u0434\u0435\u043B\u0435."
  testimonies:
  - witnessName: "\u041A\u043E\u0443\u043B (\u0441\u0442\u0430\u0440\u0448\u0438\u0439
      \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C)"
    baseTestimony: "\xAB\u041B\u043E\u0433\u0438\u043D \u0411\u0435\u043B\u043E\u0432\u0430,
      \u0434\u0430\u043D\u043D\u044B\u0435 \u043D\u0430 \u0435\u0433\u043E \u0444\u043B\u0435\u0448\u043A\u0435,
      \u043C\u043E\u0442\u0438\u0432 \u2014 \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u0435\u043D
      \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u043E\u0439. \u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0438\u043D\u0441\u0430\u0439\u0434\u0435\u0440. \u041F\u043B\u044E\u0441
      \u0438\u043F\u043E\u0442\u0435\u043A\u0430. \u0414\u0435\u043D\u044C\u0433\u0438
      \u043E\u0442 \u043F\u0440\u043E\u0434\u0430\u0436\u0438 \u0434\u0430\u043D\u043D\u044B\u0445
      \u0440\u0435\u0448\u0438\u043B\u0438 \u0431\u044B \u0435\u0433\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435
      \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B.\xBB"
    clarification: "\xAB\u041D\u043E \u044F \u043F\u043E\u0434\u043D\u044F\u043B
      \u0444\u0438\u043D\u0430\u043D\u0441\u044B \u0411\u0435\u043B\u043E\u0432\u0430.
      \u041D\u0438\u043A\u0430\u043A\u0438\u0445 \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
      \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439 \u2014 \u043D\u0438
      \u043D\u0430 \u0435\u0433\u043E \u0441\u0447\u0435\u0442\u0430, \u043D\u0438
      \u043D\u0430 \u0441\u0447\u0435\u0442\u0430 \u0436\u0435\u043D\u044B. \u0417\u0430
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0433\u043E\u0434 \u2014
      \u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u0430
      \u0438 \u0434\u0435\u0442\u0441\u043A\u0438\u0435. \u0415\u0441\u043B\u0438
      \u043E\u043D \u043F\u0440\u043E\u0434\u0430\u043B \u0434\u0430\u043D\u043D\u044B\u0435
      \u2014 \u0433\u0434\u0435 \u0434\u0435\u043D\u044C\u0433\u0438? \u041A\u0440\u0438\u043F\u0442\u043E\u0432\u0430\u043B\u044E\u0442\u043D\u044B\u0445
      \u043A\u043E\u0448\u0435\u043B\u044C\u043A\u043E\u0432 \u043D\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u043E.\xBB"
  - witnessName: "\u041F\u044D\u0439\u0434\u0436 (\u044D\u043A\u0441\u043F\u0435\u0440\u0442-\u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A)"
    baseTestimony: "\xAB\u0422\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438
      \u2014 \u0432\u0441\u0451 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
      \u043D\u0430 \u0411\u0435\u043B\u043E\u0432\u0430. \u0415\u0433\u043E \u043B\u043E\u0433\u0438\u043D,
      \u0432\u0440\u0435\u043C\u044F \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
      \u0441 \u0435\u0433\u043E \u043F\u043E\u0437\u0434\u043D\u0438\u043C\u0438
      \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u0430\u043C\u0438, USB \u0432 \u0435\u0433\u043E
      \u0441\u0442\u043E\u043B\u0435. \u0426\u0435\u043F\u043E\u0447\u043A\u0430
      \u0443\u043B\u0438\u043A \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u0430.
      \u041D\u043E MAC-\u0430\u0434\u0440\u0435\u0441 \u0432 \u043B\u043E\u0433\u0430\u0445
      \u043D\u0435 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B\u0441\u044F \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u043E
      \u2014 \u0441\u0442\u043E\u0438\u0442 \u043F\u0435\u0440\u0435\u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C.\xBB"
    clarification: "\xAB\u041F\u0435\u0440\u0435\u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B\u0430.
      MAC-\u0430\u0434\u0440\u0435\u0441 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430
      \u043D\u0435 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
      \u043D\u0438 \u043E\u0434\u043D\u043E\u043C\u0443 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0443
      \u0411\u0435\u043B\u043E\u0432\u0430. \u0421\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
      \u0441 \u0440\u0430\u0431\u043E\u0447\u0435\u0439 \u0441\u0442\u0430\u043D\u0446\u0438\u0435\u0439
      \u0417\u043E\u0442\u043E\u0432\u0430. \u041A\u0430\u043A \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440,
      \u0417\u043E\u0442\u043E\u0432 \u043C\u043E\u0436\u0435\u0442 \u0441\u0431\u0440\u043E\u0441\u0438\u0442\u044C
      \u043B\u044E\u0431\u043E\u0439 \u043F\u0430\u0440\u043E\u043B\u044C \u0438
      \u0432\u043E\u0439\u0442\u0438 \u043F\u043E\u0434 \u043B\u044E\u0431\u043E\u0439
      \u0443\u0447\u0451\u0442\u043D\u043E\u0439 \u0437\u0430\u043F\u0438\u0441\u044C\u044E.
      \u042D\u0442\u043E \u0435\u0433\u043E \u0448\u0442\u0430\u0442\u043D\u0430\u044F
      \u0444\u0443\u043D\u043A\u0446\u0438\u044F.\xBB"
  - witnessName: "\u041D\u044D\u0448 (\u043F\u043E\u043B\u0435\u0432\u043E\u0439
      \u0430\u0433\u0435\u043D\u0442)"
    baseTestimony: "\xAB\u0417\u043E\u0442\u043E\u0432 \u0441\u0430\u043C \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B
      \u0443\u0442\u0435\u0447\u043A\u0443 \u0438 \u0434\u043E\u043B\u043E\u0436\u0438\u043B.
      \u041E\u0431\u044B\u0447\u043D\u043E \u0442\u043E\u0442 \u043A\u0442\u043E
      \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u2014 \u043D\u0435
      \u0432\u0438\u043D\u043E\u0432\u0430\u0442. \u041D\u043E \u0417\u043E\u0442\u043E\u0432
      \u0438\u043C\u0435\u043B \u043F\u043E\u043B\u043D\u044B\u0439 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0439
      \u0434\u043E\u0441\u0442\u0443\u043F \u043A\u043E \u0432\u0441\u0435\u043C
      \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u043C. \u041C\u043E\u0433 \u043F\u043E\u0434\u043C\u0435\u043D\u0438\u0442\u044C
      \u043B\u043E\u0433\u0438, \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0443\u0447\u0451\u0442\u043D\u044B\u0435
      \u0437\u0430\u043F\u0438\u0441\u0438, \u0441\u0442\u0435\u0440\u0435\u0442\u044C
      \u0441\u043B\u0435\u0434\u044B. \u0424\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u0430\u044F
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u0417\u043E\u0442\u043E\u0432\u0430
      \u2014 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u044E.\xBB"
    clarification: "\xAB\u0417\u043E\u0442\u043E\u0432 \u0434\u0432\u0435 \u043D\u0435\u0434\u0435\u043B\u0438
      \u043D\u0430\u0437\u0430\u0434 \u043E\u0444\u043E\u0440\u043C\u0438\u043B \u043A\u0440\u0435\u0434\u0438\u0442
      \u043D\u0430 $50 000 \u2014 '\u0440\u0435\u043C\u043E\u043D\u0442 \u0434\u043E\u043C\u0430'.
      \u041D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0447\u0435\u043A\u0430
      \u0437\u0430 \u0441\u0442\u0440\u043E\u0439\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B.
      \u0414\u0435\u043D\u044C\u0433\u0438 \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0435\u043D\u044B
      \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u0442\u0440\u0451\u0445
      \u0434\u043D\u0435\u0439. \u0414\u043E\u043C \u0417\u043E\u0442\u043E\u0432\u0430
      \u2014 \u0441\u044A\u0451\u043C\u043D\u0430\u044F \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0430.
      \u0420\u0435\u043C\u043E\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043D\u0435\u0447\u0435\u0433\u043E.\xBB"
  contradictions:
  - witnessA: "\u041A\u043E\u0443\u043B"
    witnessB: "\u041F\u044D\u0439\u0434\u0436"
    description: "\u041A\u043E\u0443\u043B \u0441\u0447\u0438\u0442\u0430\u0435\u0442
      \u0443\u043B\u0438\u043A\u0438 \u043F\u0440\u043E\u0442\u0438\u0432 \u0411\u0435\u043B\u043E\u0432\u0430
      \u0436\u0435\u043B\u0435\u0437\u043D\u044B\u043C\u0438 \u2014 \u043B\u043E\u0433\u0438\u043D,
      \u0444\u043B\u0435\u0448\u043A\u0430, \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u0438
      \u0434\u043E\u043F\u043E\u0437\u0434\u043D\u0430. \u041F\u044D\u0439\u0434\u0436
      \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0430 \u0447\u0442\u043E
      MAC-\u0430\u0434\u0440\u0435\u0441 \u0432 \u043B\u043E\u0433\u0430\u0445 \u043D\u0435
      \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u043D\u043E\u0443\u0442\u0431\u0443\u043A\u0443
      \u0411\u0435\u043B\u043E\u0432\u0430."
  - witnessA: "\u041A\u043E\u0443\u043B"
    witnessB: "\u041D\u044D\u0448"
    description: "\u041A\u043E\u0443\u043B \u0443\u0432\u0435\u0440\u0435\u043D \u0432
      \u0432\u0438\u043D\u043E\u0432\u043D\u043E\u0441\u0442\u0438 \u0411\u0435\u043B\u043E\u0432\u0430
      \u2014 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0438\u043D\u0441\u0430\u0439\u0434\u0435\u0440. \u041D\u044D\u0448 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
      \u0447\u0442\u043E \u0443 \u0411\u0435\u043B\u043E\u0432\u0430 \u043D\u0435\u0442
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
      \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439, \u0430
      \u0417\u043E\u0442\u043E\u0432 \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0438\u043B
      $50,000."
  standardQuestions:
  - question: "\u0412\u044B \u0441\u043A\u0430\u0447\u0438\u0432\u0430\u043B\u0438
      \u0434\u0430\u043D\u043D\u044B\u0435 \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432?"
    answer: "\xAB\u041D\u0435\u0442. \u042F \u043D\u0438\u043A\u043E\u0433\u0434\u0430
      \u043D\u0435 \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0441\u044F \u043A
      \u0431\u0430\u0437\u0435 \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u043E\u0432
      \u2014 \u044D\u0442\u043E \u043D\u0435 \u043C\u043E\u044F \u0437\u043E\u043D\u0430
      \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438.
      \u042F \u0437\u0430\u043D\u0438\u043C\u0430\u044E\u0441\u044C \u0438\u043D\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u043E\u0439:
      \u0441\u0435\u0440\u0432\u0435\u0440\u044B, \u0441\u0435\u0442\u0438, \u0431\u044D\u043A\u0430\u043F\u044B.
      \u041A\u043B\u0438\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0434\u0430\u043D\u043D\u044B\u043C\u0438
      \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F \u0434\u0440\u0443\u0433\u043E\u0439
      \u043E\u0442\u0434\u0435\u043B.\xBB"
    pressureChange: 0
  - question: "\u0424\u043B\u0435\u0448\u043A\u0430 \u0441 \u0434\u0430\u043D\u043D\u044B\u043C\u0438
      \u043D\u0430\u0439\u0434\u0435\u043D\u0430 \u0432 \u0432\u0430\u0448\u0435\u043C
      \u0441\u0442\u043E\u043B\u0435. \u041A\u0430\u043A \u043E\u043D\u0430 \u0442\u0443\u0434\u0430
      \u043F\u043E\u043F\u0430\u043B\u0430?"
    answer: "(\u0420\u0430\u0441\u0442\u0435\u0440\u044F\u043D\u043D\u043E.) \xAB\u042F
      \u043D\u0435 \u0437\u043D\u0430\u044E. \u042D\u0442\u043E \u043D\u0435 \u043C\u043E\u044F
      \u0444\u043B\u0435\u0448\u043A\u0430. \u0423 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C
      \u0441\u0432\u043E\u044F \u2014 \u0441\u0438\u043D\u044F\u044F, \u0441 \u043B\u043E\u0433\u043E\u0442\u0438\u043F\u043E\u043C.
      \u042D\u0442\u0430 \u0447\u0451\u0440\u043D\u0430\u044F, \u0431\u0435\u0437
      \u043C\u0430\u0440\u043A\u0438\u0440\u043E\u0432\u043A\u0438. \u042F \u0435\u0451
      \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B.
      \u041B\u044E\u0431\u043E\u0439 \u043C\u043E\u0433 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C
      \u0435\u0451 \u0432 \u043C\u043E\u0439 \u0441\u0442\u043E\u043B \u2014 \u044F\u0449\u0438\u043A\u0438
      \u043D\u0435 \u0437\u0430\u043F\u0438\u0440\u0430\u044E\u0442\u0441\u044F.\xBB"
    pressureChange: 0
  - question: "\u0412\u044B \u0431\u044B\u043B\u0438 \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u043D\u044B
      \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u043E\u0439. \u041F\u0440\u043E\u0441\u0438\u043B\u0438
      \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u0435 \u0434\u0432\u0430\u0436\u0434\u044B."
    answer: "\xAB\u0414\u0430, \u043F\u0440\u043E\u0441\u0438\u043B. \u0418 \u043C\u043D\u0435
      \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0438. \u041D\u043E \u044D\u0442\u043E
      \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0447\u0430\u044F
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u2014 \u043D\u0435 \u043F\u043E\u0432\u043E\u0434
      \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0442\u044C \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435.
      \u042F \u0438\u0441\u043A\u0430\u043B \u0434\u0440\u0443\u0433\u0443\u044E
      \u0440\u0430\u0431\u043E\u0442\u0443, \u0430 \u043D\u0435 \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B
      \u0434\u0430\u043D\u043D\u044B\u0435.\xBB"
    pressureChange: 0
  - question: "\u0417\u0430\u0447\u0435\u043C \u0432\u044B \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0438\u0441\u044C
      \u0434\u043E\u043F\u043E\u0437\u0434\u043D\u0430 \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
      \u043C\u0435\u0441\u044F\u0446?"
    answer: "\xAB\u0417\u043E\u0442\u043E\u0432 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B
      \u043F\u043E\u043C\u043E\u0447\u044C \u0441 \u043C\u0438\u0433\u0440\u0430\u0446\u0438\u0435\u0439
      \u0441\u0435\u0440\u0432\u0435\u0440\u043E\u0432. \u0414\u0430\u0432\u0430\u043B
      \u0437\u0430\u0434\u0430\u043D\u0438\u044F \u043F\u043E\u0441\u043B\u0435 \u0440\u0430\u0431\u043E\u0447\u0435\u0433\u043E
      \u0434\u043D\u044F. \u0422\u0435\u043F\u0435\u0440\u044C \u044F \u043F\u043E\u043D\u0438\u043C\u0430\u044E
      \u0437\u0430\u0447\u0435\u043C \u2014 \u0435\u043C\u0443 \u043D\u0443\u0436\u043D\u043E
      \u0431\u044B\u043B\u043E \u043C\u043E\u0451 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
      \u0432 \u043B\u043E\u0433\u0430\u0445 \u0432 \u043D\u0435\u0440\u0430\u0431\u043E\u0447\u0435\u0435
      \u0432\u0440\u0435\u043C\u044F. \u0427\u0442\u043E\u0431\u044B \u044D\u0442\u043E
      \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B\u043E \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E.\xBB"
    pressureChange: 0
  conditionalQuestions:
