    pressureChange: 1
  - requiredChoiceType: 2
    requiredChoiceId: "\u041F\u044D\u0439\u0434\u0436 (\u044D\u043A\u0441\u043F\u0435\u0440\u0442-\u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A)"
    question: "\u041F\u044D\u0439\u0434\u0436 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442:
