    pressureChange: 1
  - requiredChoiceType: 1
    requiredChoiceId: evidence_bankstatement
    question: "GreenTech \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u0431\u044B\u0432\u0448\u0438\u043C
