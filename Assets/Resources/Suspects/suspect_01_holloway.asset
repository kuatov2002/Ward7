    baseTestimony: "\xAB\u0421\u0430\u043B\u0430\u0441 \u043F\u043E\u0434\u0430\u043B
      \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u043E \u043F\u0440\u0438\u043D\u0443\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
      \u0440\u0430\u0441\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u0438 \u043F\u0430\u0440\u0442\u043D\u0451\u0440\u0441\u0442\u0432\u0430
      \u0437\u0430 \u0434\u0432\u0430 \u0434\u043D\u044F \u0434\u043E \u043F\u043E\u0436\u0430\u0440\u0430.
      \u041F\u043E \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u043C \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0430
      \u2014 \u043F\u0440\u0438 \u043E\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0438
      \u043E\u0434\u043D\u043E\u0433\u043E \u043F\u0430\u0440\u0442\u043D\u0451\u0440\u0430
      \u0435\u0433\u043E \u0434\u043E\u043B\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
      \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442 \u0434\u0440\u0443\u0433\u043E\u043C\u0443.
      \u041E\u0442\u0434\u0435\u043B\u044C\u043D\u043E: \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u043D\u044B\u0435
      \u0437\u0430\u043F\u0438\u0441\u0438 \u0413\u043E\u043C\u0435\u0441\u0430 \u0437\u0430
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E \u043D\u0435\u0434\u0435\u043B\u044E
      \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442 \u043D\u0435\u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043C\u0443\u044E
      \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C \u2014 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u044E.\xBB"
    clarification: "\xAB\u041F\u0440\u043E\u0432\u0435\u0440\u0438\u043B. \u0421\u0435\u043C\u044C
      \u0437\u0432\u043E\u043D\u043A\u043E\u0432 \u0421\u0430\u043B\u0430\u0441\u0443
      \u0437\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E \u043D\u0435\u0434\u0435\u043B\u044E.
      \u0413\u043E\u043C\u0435\u0441 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
      \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0443 \u0425\u043E\u043B\u043B\u043E\u0443\u044D\u044F
      \u2014 \u043E\u043D \u0431\u044B\u043B \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u043E\u043C
      \u0421\u0430\u043B\u0430\u0441\u0430 \u0432\u043D\u0443\u0442\u0440\u0438 \u0441\u043A\u043B\u0430\u0434\u0430.
      \u0417\u043D\u0430\u043B \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u0435,
      \u0437\u043D\u0430\u043B \u043A\u0442\u043E \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442
      \u043D\u043E\u0447\u044C\u044E. \u0421\u0430\u043B\u0430\u0441 \u0437\u043D\u0430\u043B
      \u0447\u0442\u043E \u0413\u043E\u043C\u0435\u0441 \u0431\u0443\u0434\u0435\u0442
      \u0442\u0430\u043C.\xBB"
