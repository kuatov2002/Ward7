    answer: "(\u0412\u0441\u0442\u0430\u0451\u0442. \u0421\u0430\u0434\u0438\u0442\u0441\u044F
      \u043E\u0431\u0440\u0430\u0442\u043D\u043E.) \xAB\u041D\u0435\u0442. \u0413\u043E\u043C\u0435\u0441
      \u0431\u044B\u043B \u0445\u043E\u0440\u043E\u0448\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C.
      \u0415\u0441\u043B\u0438 \u0412\u0438\u043A\u0442\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
      \u0435\u0433\u043E \u043A\u0430\u043A \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u0430
